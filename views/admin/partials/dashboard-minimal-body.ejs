<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <%= title || 'Admin Dashboard' %>
        </h1>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Basic Info</h6>
                </div>
                <div class="card-body">
                    <p><strong>Title:</strong>
                        <%= title %>
                    </p>
                    <p><strong>Current Page:</strong>
                        <%= currentPage %>
                    </p>
                    <p><strong>User:</strong>
                        <%= user ? (user.email || (user.firstName + ' ' + user.lastName)) : 'No user' %>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Stats</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 mb-2"><strong>Total Users:</strong>
                            <%= typeof totalUsers !=='undefined' ? totalUsers : 0 %>
                        </div>
                        <div class="col-6 mb-2"><strong>Total Patients:</strong>
                            <%= typeof totalPatients !=='undefined' ? totalPatients : 0 %>
                        </div>
                        <div class="col-6 mb-2"><strong>Total Providers:</strong>
                            <%= typeof totalProviders !=='undefined' ? totalProviders : 0 %>
                        </div>
                        <div class="col-6 mb-2"><strong>Total Appointments:</strong>
                            <%= typeof totalAppointments !=='undefined' ? totalAppointments : 0 %>
                        </div>
                        <div class="col-6 mb-2"><strong>Pending Verifications:</strong>
                            <%= typeof pendingVerifications !=='undefined' ? pendingVerifications : 0 %>
                        </div>
                        <div class="col-6 mb-2"><strong>Pending Services:</strong>
                            <%= typeof pendingServices !=='undefined' ? pendingServices : 0 %>
                        </div>
                        <div class="col-6 mb-2"><strong>Pending Documents:</strong>
                            <%= typeof pendingDocuments !=='undefined' ? pendingDocuments : 0 %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Data Arrays</h6>
                </div>
                <div class="card-body">
                    <p><strong>Recent Appointments:</strong>
                        <%= recentAppointments ? recentAppointments.length : 0 %> items
                    </p>
                    <p><strong>Pending Verifications:</strong>
                        <%= pendingVerifications ? pendingVerifications.length : 0 %> items
                    </p>
                    <p><strong>Recent Activity:</strong>
                        <%= recentActivity ? recentActivity.length : 0 %> items
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Navigation</h6>
                </div>
                <div class="card-body">
                    <a href="/api/v1/admin/test">Test Route</a> |
                    <a href="/api/v1/admin/html-test">HTML Test</a> |
                    <a href="/api/v1/admin/dashboard-simple">Simple Dashboard</a> |
                    <a href="/admin/dashboard">Full Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</div>