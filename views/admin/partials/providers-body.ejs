<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-user-md mr-2"></i>Manage Providers
        </h1>
        <p class="text-muted">View and manage all registered providers</p>
    </div>
    <div>
        <button class="btn btn-primary" data-toggle="modal" data-target="#newProviderModal">
            <i class="fas fa-plus mr-2"></i>Add New Provider
        </button>
        <button class="btn btn-outline-secondary ml-2" data-toggle="modal" data-target="#importCsvModal">
            <i class="fas fa-file-csv mr-2"></i>Import CSV
        </button>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-left-primary shadow h-100 py-3 text-center">
            <div class="card-body">
                <div class="h4 mb-1 font-weight-bold text-gray-800" id="totalProviders">
                    <%= Array.isArray(providers) ? providers.length : 0 %>
                </div>
                <div class="text-xs text-uppercase text-primary font-weight-bold">Total Providers</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-left-success shadow h-100 py-3 text-center">
            <div class="card-body">
                <div class="h4 mb-1 font-weight-bold text-gray-800" id="verifiedProviders">0</div>
                <div class="text-xs text-uppercase text-success font-weight-bold">Verified</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-left-warning shadow h-100 py-3 text-center">
            <div class="card-body">
                <div class="h4 mb-1 font-weight-bold text-gray-800" id="pendingProviders">0</div>
                <div class="text-xs text-uppercase text-warning font-weight-bold">Pending</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-left-info shadow h-100 py-3 text-center">
            <div class="card-body">
                <div class="h4 mb-1 font-weight-bold text-gray-800" id="newProvidersThisMonth">0</div>
                <div class="text-xs text-uppercase text-info font-weight-bold">New This Month</div>
            </div>
        </div>
    </div>
</div>

<!-- View Provider Modal -->
<div class="modal fade" id="viewProviderModal" tabindex="-1" role="dialog" aria-labelledby="viewProviderLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewProviderLabel">Provider Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <div class="font-weight-bold">Full Name</div>
                        <div id="vFullName" class="text-muted">-</div>
                    </div>
                    <div class="col-md-6">
                        <div class="font-weight-bold">Email</div>
                        <div id="vEmail" class="text-muted">-</div>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <div class="font-weight-bold">Phone</div>
                        <div id="vPhone" class="text-muted">-</div>
                    </div>
                    <div class="col-md-4">
                        <div class="font-weight-bold">Specialization</div>
                        <div id="vSpec" class="text-muted">-</div>
                    </div>
                    <div class="col-md-4">
                        <div class="font-weight-bold">License</div>
                        <div id="vLicense" class="text-muted">-</div>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <div class="font-weight-bold">Verification Status</div>
                        <div id="vStatus" class="text-muted">-</div>
                    </div>
                    <div class="col-md-4">
                        <div class="font-weight-bold">Registered</div>
                        <div id="vCreatedAt" class="text-muted">-</div>
                    </div>
                    <div class="col-md-4">
                        <div class="font-weight-bold">ID</div>
                        <div id="vId" class="text-monospace small">-</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Provider Modal -->
<div class="modal fade" id="editProviderModal" tabindex="-1" role="dialog" aria-labelledby="editProviderLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editProviderLabel">Edit Provider</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="eFirstName">First Name</label>
                        <input type="text" class="form-control" id="eFirstName">
                    </div>
                    <div class="form-group col-md-6">
                        <label for="eLastName">Last Name</label>
                        <input type="text" class="form-control" id="eLastName">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="eEmail">Email</label>
                        <input type="email" class="form-control" id="eEmail">
                    </div>
                    <div class="form-group col-md-6">
                        <label for="ePhone">Phone</label>
                        <input type="text" class="form-control" id="ePhone">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="eProfessionalTitle">Professional Title</label>
                        <input type="text" class="form-control" id="eProfessionalTitle">
                    </div>
                    <div class="form-group col-md-6">
                        <label for="eSpecialization">Specialization</label>
                        <input type="text" class="form-control" id="eSpecialization">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="eLicenseNumber">License Number</label>
                        <input type="text" class="form-control" id="eLicenseNumber">
                    </div>
                    <div class="form-group col-md-3">
                        <label for="eYearsOfExperience">Years of Experience</label>
                        <input type="number" min="0" class="form-control" id="eYearsOfExperience">
                    </div>
                    <div class="form-group col-md-3">
                        <label for="eVerificationStatus">Verification</label>
                        <select class="form-control" id="eVerificationStatus">
                            <option value="pending">Pending</option>
                            <option value="approved">Approved</option>
                            <option value="rejected">Rejected</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveProviderBtn">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Import CSV Modal -->
<div class="modal fade" id="importCsvModal" tabindex="-1" role="dialog" aria-labelledby="importCsvLabel"
    aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="importCsvLabel">Import Providers via CSV</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-2">Upload a CSV with columns:</p>
                <code>firstName,lastName,email,password,phone,professionalTitle,specialization,licenseNumber,yearsOfExperience</code>
                <form id="csvUploadForm">
                    <div class="form-group mt-3">
                        <input type="file" class="form-control" id="csvFile" accept=".csv,text/csv" required>
                    </div>
                </form>
                <div id="csvResult" class="small"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="uploadCsvBtn">Upload</button>
            </div>
        </div>
    </div>
</div>

<!-- Search and Filter -->
<div class="card shadow mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                    </div>
                    <input type="text" class="form-control" id="searchInput" placeholder="Search providers...">
                </div>
            </div>
            <div class="col-md-6">
                <div class="d-flex justify-content-end">
                    <select class="form-control mr-2" id="statusFilter" style="width: auto;">
                        <option value="">All Statuses</option>
                        <option value="approved">Approved</option>
                        <option value="pending">Pending</option>
                        <option value="rejected">Rejected</option>
                    </select>
                    <select class="form-control mr-2" id="specializationFilter" style="width: auto;">
                        <option value="">All Specializations</option>
                        <option value="cardiology">Cardiology</option>
                        <option value="dermatology">Dermatology</option>
                        <option value="neurology">Neurology</option>
                    </select>
                    <button class="btn btn-outline-secondary" type="button" id="exportBtn">
                        <i class="fas fa-download mr-1"></i>Export
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Providers Table -->
<div class="card shadow">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-list mr-2"></i>Provider List</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="providersTable">
                <thead>
                    <tr>
                        <th>Provider</th>
                        <th>Specialization</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>License</th>
                        <th>Verification Status</th>
                        <th>Registration Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="providersTableBody">
                    <% if (Array.isArray(providers) && providers.length> 0) { %>
                        <% providers.forEach(function(pr){ %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar mr-3">
                                            <img src="<%= pr.profileImage || '/uploads/avatar-fallback.svg' %>"
                                                alt="Avatar" class="rounded-circle" width="40" height="40"
                                                onerror="this.onerror=null;this.src='/uploads/avatar-fallback.svg'">
                                        </div>
                                        <div>
                                            <div class="font-weight-bold">
                                                <%= [pr.professionalTitle, pr.firstName,
                                                    pr.lastName].filter(Boolean).join(' ') %></div>
                                            <small class="text-muted">ID: <%= pr._id %></small>
                                        </div>
                                    </div>
                                </td>
                                <td><%= pr.specialization || ' N/A' %>
                                </td>
                                <td>
                                    <%= pr.email || 'N/A' %>
                                </td>
                                <td>
                                    <%= pr.phone || 'N/A' %>
                                </td>
                                <td>
                                    <%= pr.licenseNumber || 'N/A' %>
                                </td>
                                <td>
                                    <% const status=(pr.verificationStatus || (pr.isVerified ? 'approved' : 'pending'
                                        )).toLowerCase(); %>
                                        <% const badge=status==='approved' ? 'success' : status==='pending' ? 'warning'
                                            : status==='rejected' ? 'danger' : 'secondary' ; %>
                                            <span class="badge badge-<%= badge %> text-capitalize">
                                                <%= status %>
                                            </span>
                                </td>
                                <td>
                                    <%= pr.createdAt ? new Date(pr.createdAt).toLocaleDateString() : 'N/A' %>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <button class="btn btn-sm btn-outline-primary"
                                            onclick="viewProvider('<%= pr._id %>')" title="View"><i
                                                class="fas fa-eye"></i></button>
                                        <button class="btn btn-sm btn-outline-warning"
                                            onclick="editProvider('<%= pr._id %>')" title="Edit"><i
                                                class="fas fa-edit"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="text-center text-muted">No providers found.</td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- New Provider Modal -->
<div class="modal fade" id="newProviderModal" tabindex="-1" role="dialog" aria-labelledby="newProviderModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <!-- Modal Header -->
            <div class="modal-header"
                style="background: linear-gradient(90deg, #06b6d4, #3b82f6); color: white; border-radius: 0.5rem 0.5rem 0 0;">
                <h5 class="modal-title font-weight-bold" id="newProviderModalLabel">
                    <i class="fas fa-user-plus mr-2"></i>Add New Provider
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body p-4">
                <form id="newProviderForm">
                    <div class="row">
                        <!-- Personal Information -->
                        <div class="col-12 mb-4">
                            <h6 class="text-primary font-weight-bold mb-3">
                                <i class="fas fa-user mr-2"></i>Personal Information
                            </h6>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="firstName" class="form-label font-weight-bold">First Name <span
                                    class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="firstName" name="firstName" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="lastName" class="form-label font-weight-bold">Last Name <span
                                    class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="lastName" name="lastName" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label font-weight-bold">Email Address <span
                                    class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="email" name="email" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="phone" class="form-label font-weight-bold">Phone Number <span
                                    class="text-danger">*</span></label>
                            <input type="tel" class="form-control" id="phone" name="phone" required>
                        </div>

                        <!-- Professional Information -->
                        <div class="col-12 mb-4 mt-4">
                            <h6 class="text-primary font-weight-bold mb-3">
                                <i class="fas fa-briefcase-medical mr-2"></i>Professional Information
                            </h6>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="professionalTitle" class="form-label font-weight-bold">Professional
                                Title</label>
                            <select class="form-control" id="professionalTitle" name="professionalTitle">
                                <option value="">Select Title</option>
                                <option value="Dr.">Dr.</option>
                                <option value="Prof.">Prof.</option>
                                <option value="Mr.">Mr.</option>
                                <option value="Ms.">Ms.</option>
                                <option value="Mrs.">Mrs.</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="specialization" class="form-label font-weight-bold">Specialization <span
                                    class="text-danger">*</span></label>
                            <select class="form-control" id="specialization" name="specialization" required>
                                <option value="">Select Specialization</option>
                                <option value="General Medicine">General Medicine</option>
                                <option value="Cardiology">Cardiology</option>
                                <option value="Dermatology">Dermatology</option>
                                <option value="Neurology">Neurology</option>
                                <option value="Pediatrics">Pediatrics</option>
                                <option value="Orthopedics">Orthopedics</option>
                                <option value="Gynecology">Gynecology</option>
                                <option value="Psychiatry">Psychiatry</option>
                                <option value="Radiology">Radiology</option>
                                <option value="Emergency Medicine">Emergency Medicine</option>
                                <option value="Internal Medicine">Internal Medicine</option>
                                <option value="Surgery">Surgery</option>
                                <option value="Anesthesiology">Anesthesiology</option>
                                <option value="Pathology">Pathology</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="licenseNumber" class="form-label font-weight-bold">License Number <span
                                    class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="licenseNumber" name="licenseNumber" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="yearsOfExperience" class="form-label font-weight-bold">Years of
                                Experience</label>
                            <input type="number" class="form-control" id="yearsOfExperience" name="yearsOfExperience"
                                min="0" max="50">
                        </div>

                        <!-- Account Settings -->
                        <div class="col-12 mb-4 mt-4">
                            <h6 class="text-primary font-weight-bold mb-3">
                                <i class="fas fa-cog mr-2"></i>Account Settings
                            </h6>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="password" class="form-label font-weight-bold">Password <span
                                    class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="password" name="password" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="confirmPassword" class="form-label font-weight-bold">Confirm Password <span
                                    class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword"
                                required>
                        </div>

                        <div class="col-12 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isActive" name="isActive" checked>
                                <label class="form-check-label font-weight-bold" for="isActive">
                                    Active Account
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Modal Footer -->
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times mr-2"></i>Cancel
                </button>
                <button type="button" class="btn btn-primary" id="saveProviderBtn"
                    style="background: linear-gradient(90deg, #06b6d4, #3b82f6); border: none;">
                    <i class="fas fa-save mr-2"></i>Save Provider
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Custom Styles for the Modal -->
<style>
    #newProviderModal .modal-content {
        border-radius: 1rem;
        overflow: hidden;
    }

    #newProviderModal .form-control {
        border-radius: 0.5rem;
        border: 2px solid #e3f2fd;
        transition: all 0.3s ease;
    }

    #newProviderModal .form-control:focus {
        border-color: #06b6d4;
        box-shadow: 0 0 0 0.2rem rgba(6, 182, 212, 0.25);
    }

    #newProviderModal .form-label {
        color: #374151;
        font-size: 0.9rem;
    }

    #newProviderModal .modal-header {
        border-bottom: none;
    }

    #newProviderModal .modal-footer {
        border-top: 1px solid #e5e7eb;
    }

    #newProviderModal .btn-primary {
        border-radius: 0.5rem;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    #newProviderModal .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(6, 182, 212, 0.4);
    }

    #newProviderModal .btn-secondary {
        border-radius: 0.5rem;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
    }

    #newProviderModal .text-primary {
        color: #06b6d4 !important;
    }

    #newProviderModal .form-check-input:checked {
        background-color: #06b6d4;
        border-color: #06b6d4;
    }

    /* Animation for modal appearance */
    #newProviderModal.fade .modal-dialog {
        transition: transform 0.3s ease-out;
        transform: translate(0, -50px);
    }

    #newProviderModal.show .modal-dialog {
        transform: none;
    }
</style>

<!-- JavaScript for the Modal -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const newProviderForm = document.getElementById('newProviderForm');
        const saveProviderBtn = document.getElementById('saveProviderBtn');
        const confirmPasswordField = document.getElementById('confirmPassword');
        const passwordField = document.getElementById('password');

        // Password confirmation validation
        function validatePassword() {
            if (passwordField.value !== confirmPasswordField.value) {
                confirmPasswordField.setCustomValidity('Passwords do not match');
                return false;
            } else {
                confirmPasswordField.setCustomValidity('');
                return true;
            }
        }

        passwordField.addEventListener('input', validatePassword);
        confirmPasswordField.addEventListener('input', validatePassword);

        // Form submission
        saveProviderBtn.addEventListener('click', async function () {
            if (!newProviderForm.checkValidity()) {
                newProviderForm.reportValidity();
                return;
            }

            if (!validatePassword()) {
                confirmPasswordField.reportValidity();
                return;
            }

            // Show loading state
            saveProviderBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Saving...';
            saveProviderBtn.disabled = true;

            try {
                const formData = new FormData(newProviderForm);
                const data = Object.fromEntries(formData);

                // Add role and verification status
                data.role = 'provider';
                data.verificationStatus = 'pending';
                data.isVerified = false;

                const response = await fetch('/api/admin/providers', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    // Show success message
                    showNotification('Provider created successfully!', 'success');

                    // Close modal and reset form
                    $('#newProviderModal').modal('hide');
                    newProviderForm.reset();

                    // Refresh the providers list
                    location.reload();
                } else {
                    showNotification(result.message || 'Failed to create provider', 'error');
                }
            } catch (error) {
                console.error('Error creating provider:', error);
                showNotification('An error occurred while creating the provider', 'error');
            } finally {
                // Reset button state
                saveProviderBtn.innerHTML = '<i class="fas fa-save mr-2"></i>Save Provider';
                saveProviderBtn.disabled = false;
            }
        });

        // Reset form when modal is closed
        $('#newProviderModal').on('hidden.bs.modal', function () {
            newProviderForm.reset();
            confirmPasswordField.setCustomValidity('');
        });

        // Notification function
        function showNotification(message, type) {
            const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const notification = `
                <div class="alert ${alertClass} alert-dismissible fade show position-fixed" 
                     style="top: 20px; right: 20px; z-index: 9999; min-width: 300px;" role="alert">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} mr-2"></i>
                    ${message}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            `;
            document.body.insertAdjacentHTML('beforeend', notification);

            // Auto remove after 5 seconds
            setTimeout(() => {
                const alert = document.querySelector('.alert');
                if (alert) {
                    alert.remove();
                }
            }, 5000);
        }
    });
</script>