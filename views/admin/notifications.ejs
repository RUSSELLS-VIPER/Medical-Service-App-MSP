<%- include('../layouts/sb-admin', { title: (title || 'Notifications' ), currentPage: 'admin/notifications' , body: `
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800"><i class=\"fas fa-bell mr-2\"></i>${title || 'Notifications'}</h1>
    <a href=\"/admin/dashboard\" class=\"btn btn-secondary\">← Back to Dashboard</a>
    </div>

    <div class=\"card shadow\">
        <div class=\"card-header py-3 d-flex flex-row align-items-center justify-content-between\">
            <h6 class=\"m-0 font-weight-bold text-primary\">All Notifications</h6>
            <span class=\"badge badge-info\">${(notifications && notifications.length) || 0}</span>
        </div>
        <div class=\"card-body\">
            ${notifications && notifications.length > 0 ? notifications.map(n => `
            <div class=\"notification ${n.isRead ? '' : 'unread' }\"
                style=\"background:#fff;padding:15px;margin-bottom:10px;border-left:4px solid ${n.isRead ? '#007bff'
                : '#dc3545' };border-radius:5px;\">
                <div class=\"d-flex justify-content-between\">
                    <div>
                        <div class=\"notification-title\" style=\"font-weight:bold\">${n.title}</div>
                        <div class=\"notification-message text-muted\">${n.message}</div>
                    </div>
                    <div class=\"notification-date text-muted\" style=\"font-size:0.85rem\">${new
                        Date(n.createdAt).toLocaleString()}</div>
                </div>
            </div>
            `).join('') : '<p class="text-muted">No notifications found.</p>'}
        </div>
    </div>
    ` }) %>