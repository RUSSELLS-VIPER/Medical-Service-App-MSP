<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>
        <%= typeof title !=='undefined' ? title : 'Healthcare System' %>
    </title>

    <!-- Custom fonts for this template-->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <!-- SB Admin 2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/css/sb-admin-2.min.css" rel="stylesheet">
    <!-- DataTables CSS (Bootstrap 4) -->
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" rel="stylesheet">
    <!-- Custom CSS for Service Categories -->
    <% if (typeof currentPage !=='undefined' && currentPage==='categories' ) { %>
        <link href="/css/service-categories.css" rel="stylesheet">
        <% } %>
            <style>
                /* Reset default margins and ensure full-height */
                html,
                body {
                    margin: 0 !important;
                    padding: 0 !important;
                    height: 100%;
                }

                /* Global text color: black (avoid !important so component styles/icons can override) */
                body {
                    color: #000;
                }

                p,
                h1,
                h2,
                h3,
                h4,
                h5,
                h6,
                a,
                .nav-link,
                .dropdown-item,
                small,
                label,
                span,
                div,
                th,
                td,
                li,
                dt,
                dd,
                .btn,
                .badge,
                .card,
                .card-header,
                .card-body,
                .navbar,
                .sidebar,
                .form-control {
                    color: #000;
                }

                /* Do not force icon color; let their own classes decide */
                i.fa,
                i.fas,
                i.far,
                i.fal,
                i.fab,
                .fa,
                .fas,
                .far,
                .fal,
                .fab,
                svg {
                    color: inherit;
                }

                /* Trim header and footer gaps */
                .topbar {
                    margin-bottom: 0 !important;
                }

                #content {
                    padding-bottom: 0 !important;
                }

                .container-fluid {
                    padding-top: 6px;
                    padding-bottom: 0 !important;
                }

                /* Remove trailing margins from last block in content area */
                .container-fluid>.row:last-child,
                .container-fluid>.card:last-child,
                .container-fluid>.mb-4:last-child {
                    margin-bottom: 0 !important;
                }

                #content .container-fluid>*:last-child {
                    margin-bottom: 0 !important;
                }

                #content .container-fluid .row:last-child {
                    margin-bottom: 0 !important;
                }

                .sticky-footer {
                    margin-top: 0 !important;
                    padding: 0 !important;
                    border-top: 0 !important;
                }

                .sticky-footer .container {
                    padding-top: 0 !important;
                    padding-bottom: 0 !important;
                }

                .sticky-footer .copyright {
                    margin: 0 !important;
                    padding: 4px 0 !important;
                }

                /* Remove top/bottom gaps around sidebar for patient/provider */
                html,
                body {
                    height: 100%;
                }

                .role-provider #wrapper,
                .role-patient #wrapper {
                    min-height: 100vh;
                }

                .role-provider #content-wrapper,
                .role-patient #content-wrapper {
                    min-height: 100vh;
                }

                .role-provider .sidebar,
                .role-patient .sidebar {
                    margin-top: 0 !important;
                    padding-top: 0 !important;
                    min-height: 100vh;
                    height: 100vh;
                }

                .role-provider .sidebar .sidebar-brand,
                .role-patient .sidebar .sidebar-brand {
                    margin-top: 0 !important;
                }

                /* Compact spacing for non-admin dashboards (remove top/bottom gaps) */
                .role-provider #content,
                .role-patient #content {
                    padding-top: 0 !important;
                    padding-bottom: 0 !important;
                }

                .role-provider .container-fluid,
                .role-patient .container-fluid {
                    padding-top: 0 !important;
                    padding-bottom: 0 !important;
                }

                .role-provider .sticky-footer,
                .role-patient .sticky-footer {
                    display: none !important;
                }

                .role-provider .sidebar,
                .role-patient .sidebar {
                    position: fixed;
                    top: 72px;
                    left: 0;
                    width: 14rem;
                    height: 100%;
                    overflow-y: auto;
                    z-index: 1040;
                }

                .role-provider #content-wrapper,
                .role-patient #content-wrapper {
                    margin-left: 14rem;
                    min-height: calc(100vh - 72px);
                    padding-top: 1.5rem;
                    padding-bottom: 1.5rem;
                }

                /* Prevent any decorative after element gaps */
                .sidebar::after {
                    display: none !important;
                }

                /* Ensure main content accounts for top navbar */
                body {
                    padding-top: 72px;
                    background-color: #f8f9fc;
                }

                /* Enhance cards and buttons */
                .card {
                    transition: transform 0.2s ease;
                }

                .card:hover {
                    transform: translateY(-2px);
                }

                .btn {
                    transition: all 0.2s ease;
                }

                .btn:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1) !important;
                }

                .navbar.fixed-top {
                    z-index: 1045;
                }

                #wrapper {
                    margin-top: 0;
                }

                /* Ensure sidebar text is readable on dark background */
                .sidebar.sidebar-dark .sidebar-brand,
                .sidebar.sidebar-dark .sidebar-heading,
                .sidebar.sidebar-dark .nav-item .nav-link,
                .sidebar.sidebar-dark .nav-item .nav-link span,
                .sidebar.sidebar-dark .nav-item .nav-link i {
                    color: #fff !important;
                }

                .sidebar.sidebar-dark .nav-item.active>.nav-link,
                .sidebar.sidebar-dark .nav-item .nav-link.active {
                    color: #fff !important;
                }

                .sidebar.sidebar-dark .badge-counter {
                    color: #fff !important;
                }
            </style>
</head>

<body id="page-top" class="<%= (user && user.role) ? ('role-' + user.role) : 'role-guest' %>">



    <!-- Page Wrapper -->
    <div id="wrapper">

        <!-- Sidebar -->
        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">


            <hr class="sidebar-divider my-0">

            <!-- Dashboard -->
            <li class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                <a class="nav-link" href="/<%= user?.role || 'admin' %>/dashboard">
                    <i class="fas fa-fw fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <hr class="sidebar-divider">

            <% if (user?.role==='admin' ) { %>
                <!-- Admin Menu -->
                <div class="sidebar-heading">Management</div>

                <li class="nav-item <%= currentPage==='patients'?'active':'' %>">
                    <a class="nav-link" href="/admin/patients"><i class="fas fa-user-injured"></i> Patients</a>
                </li>
                <li class="nav-item <%= currentPage==='providers'?'active':'' %>">
                    <a class="nav-link" href="/admin/providers"><i class="fas fa-user-md"></i> Providers</a>
                </li>
                <li class="nav-item <%= currentPage==='verifications'?'active':'' %>">
                    <a class="nav-link" href="/admin/verifications"><i class="fas fa-user-check"></i>
                        Verifications</a>
                </li>
                <li class="nav-item <%= currentPage==='categories'?'active':'' %>">
                    <a class="nav-link" href="/admin/categories"><i class="fas fa-list"></i> Service Categories</a>
                </li>

                <!-- Admin Notifications -->
                <li class="nav-item <%= (currentPage && currentPage.includes('notifications')) ? 'active' : '' %>">
                    <a class="nav-link d-flex align-items-center justify-content-between" href="/admin/notifications">
                        <span><i class="fas fa-bell"></i> Notifications</span>
                        <span class="badge badge-danger badge-counter ml-2">
                            <%= typeof unreadNotificationsCount !=='undefined' ? unreadNotificationsCount : 0 %>
                        </span>
                    </a>
                </li>


                <hr class="sidebar-divider">


                <% } else if (user?.role==='patient' ) { %>
                    <!-- Patient Menu -->
                    <div class="sidebar-heading">Patient Services</div>
                    <li class="nav-item <%= currentPage==='services'?'active':'' %>">
                        <a class="nav-link" href="/services"><i class="fas fa-stethoscope"></i> Book Services</a>
                    </li>
                    <li class="nav-item <%= currentPage==='appointments'?'active':'' %>">
                        <a class="nav-link" href="/patient/appointments"><i class="fas fa-calendar-check"></i> My
                            Appointments</a>
                    </li>

                    <li class="nav-item <%= (currentPage && currentPage.includes('profile')) ? 'active' : '' %>">
                        <a class="nav-link" href="/patient/profile"><i class="fas fa-user"></i> Profile</a>
                    </li>

                    <!-- Patient Notifications -->
                    <li class="nav-item <%= (currentPage && currentPage.includes('notifications')) ? 'active' : '' %>">
                        <a class="nav-link d-flex align-items-center justify-content-between"
                            href="/patient/notifications">
                            <span><i class="fas fa-bell"></i> Notifications</span>
                            <span class="badge badge-danger badge-counter ml-2">
                                <%= typeof unreadNotificationsCount !=='undefined' ? unreadNotificationsCount : 0 %>
                            </span>
                        </a>
                    </li>


                    <% } else if (user?.role==='provider' ) { %>
                        <!-- Provider Menu -->
                        <div class="sidebar-heading">Provider Services</div>
                        <li class="nav-item <%= currentPage==='appointments'?'active':'' %>">
                            <a class="nav-link" href="/provider/appointments"><i class="fas fa-calendar-check"></i>
                                Appointments</a>
                        </li>
                        <li class="nav-item <%= currentPage==='service-management'?'active':'' %>">
                            <a class="nav-link" href="/provider/service-management"><i class="fas fa-stethoscope"></i>
                                Services</a>
                        </li>

                        <!-- Quick Actions moved from dashboard -->

                        <li class="nav-item <%= currentPage==='new-service'?'active':'' %>">
                            <a class="nav-link" href="/provider/service-management?create=1"><i class="fas fa-plus"></i>
                                New Service</a>
                        </li>

                        <!-- Provider Notifications -->
                        <li
                            class="nav-item <%= (currentPage && currentPage.includes('notifications')) ? 'active' : '' %>">
                            <a class="nav-link d-flex align-items-center justify-content-between"
                                href="/provider/notifications">
                                <span><i class="fas fa-bell"></i> Notifications</span>
                                <span class="badge badge-danger badge-counter ml-2">
                                    <%= typeof unreadNotificationsCount !=='undefined' ? unreadNotificationsCount : 0 %>
                                </span>
                            </a>
                        </li>
                        <% } %>

                            <hr class="sidebar-divider">

                            <!-- Logout (all roles) -->
                            <li class="nav-item">
                                <a class="nav-link" href="/logout">
                                    <i class="fas fa-sign-out-alt"></i>
                                    <span>Logout</span>
                                </a>
                            </li>

                            <% if (user?.role==='provider' ) { %>
                                <div class="sidebar-heading">Account</div>

                                <li
                                    class="nav-item <%= (currentPage && currentPage.includes('profile')) ? 'active' : '' %>">
                                    <a class="nav-link" href="/profile"><i class="fas fa-user"></i> Profile</a>
                                </li>
                                <% } %>

                                    <hr class="sidebar-divider d-none d-md-block">

                                    <div class="text-center d-none d-md-inline">
                                        <button class="rounded-circle border-0" id="sidebarToggle"></button>
                                    </div>
        </ul>
        <!-- End Sidebar -->

        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">

            <!-- Main Content -->
            <div id="content">

                <!-- Topbar (admins only) -->
                <% const showTopbar=user && user.role==='admin' ; %>
                    <% if (false && showTopbar) { %>
                        <nav class="navbar navbar-expand navbar-light bg-white topbar static-top shadow"
                            style="margin-bottom:0!important;">

                            <!-- Sidebar Toggle (Topbar) -->
                            <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                                <i class="fa fa-bars"></i>
                            </button>

                            <!-- Topbar Search -->
                            <form
                                class="d-none d-sm-inline-block form-inline mr-auto ml-md-3 my-2 my-md-0 mw-100 navbar-search">
                                <div class="input-group">
                                    <input type="text" class="form-control bg-light border-0 small"
                                        placeholder="Search for...">
                                    <div class="input-group-append">
                                        <button class="btn btn-primary" type="button"><i
                                                class="fas fa-search fa-sm"></i></button>
                                    </div>
                                </div>
                            </form>

                            <!-- Topbar Navbar -->
                            <ul class="navbar-nav ml-auto">
                                <!-- Alerts -->
                                <li class="nav-item dropdown no-arrow mx-1">
                                    <a class="nav-link dropdown-toggle" href="#" id="alertsDropdown" role="button"
                                        data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        <i class="fas fa-bell fa-fw"></i>
                                        <span class="badge badge-danger badge-counter">
                                            <%= typeof unreadNotificationsCount !=='undefined' ?
                                                unreadNotificationsCount : 0 %>
                                        </span>
                                    </a>
                                    <div class="dropdown-list dropdown-menu dropdown-menu-right shadow animated--grow-in"
                                        aria-labelledby="alertsDropdown">
                                        <h6 class="dropdown-header">Notifications Center</h6>
                                        <% if (typeof notifications !=='undefined' && notifications &&
                                            notifications.length> 0)
                                            { %>
                                            <% notifications.slice(0,5).forEach(function(n){ %>
                                                <a class="dropdown-item d-flex align-items-center"
                                                    href="javascript:void(0)">
                                                    <div class="mr-3">
                                                        <div class="icon-circle bg-primary">
                                                            <i class="fas fa-info text-white"></i>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <div class="small text-gray-500">
                                                            <%= new Date(n.createdAt).toLocaleString() %>
                                                        </div>
                                                        <span class="font-weight-bold">
                                                            <%= n.title %>
                                                        </span>
                                                        <div class="text-truncate">
                                                            <%= n.message %>
                                                        </div>
                                                    </div>
                                                </a>
                                                <% }); %>
                                                    <% } else { %>
                                                        <div class="dropdown-item text-center small text-gray-500">
                                                            No
                                                            notifications</div>
                                                        <% } %>
                                    </div>
                                </li>
                                <!-- User Info -->
                                <li class="nav-item dropdown no-arrow">
                                    <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                                        data-toggle="dropdown">
                                        <span class="mr-2 d-none d-lg-inline text-gray-600 small">
                                            <%= user?.firstName ? `${user.firstName} ${user.lastName}` : 'User' %>
                                        </span>
                                        <img class="img-profile rounded-circle"
                                            src="https://source.unsplash.com/QAB-WJcbgJk/60x60">
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in"
                                        aria-labelledby="userDropdown">
                                        <a class="dropdown-item" href="/logout"><i
                                                class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                                            Logout</a>
                                    </div>
                                </li>
                            </ul>
                        </nav>
                        <% } %>
                            <!-- End Topbar -->

                            <!-- Page Content -->
                            <div class="container-fluid">
                                <%- body %>
                            </div>
            </div>
            <!-- End Content -->

            <!-- Footer (admin only) -->
            <% if (user && user.role==='admin' ) { %>
                <footer class="sticky-footer bg-white" style="margin-top:0!important;">
                    <div class="container my-auto" style="padding-top:6px;padding-bottom:6px;">
                        <div class="copyright text-center my-auto">
                            <span>&copy; <%= new Date().getFullYear() %> Healthcare MSP</span>
                        </div>
                    </div>
                </footer>
                <% } %>
        </div>
    </div>

    <!-- Scroll to Top -->
    <a class="scroll-to-top rounded" href="#page-top"><i class="fas fa-angle-up"></i></a>

    <!-- jQuery + Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <!-- SB Admin 2 Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/js/sb-admin-2.min.js"></script>
    <!-- Charts (used by dashboards) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@2.9.4/dist/Chart.min.js"></script>
</body>

</html>