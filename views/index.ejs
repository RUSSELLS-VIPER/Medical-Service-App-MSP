    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-white/90 to-white/50 md:from-white/80 md:to-transparent">
        </div>
        <img src="/assets/images/hero-bg.jpg" alt="Medical Professional"
            class="w-full h-full object-cover object-center" onerror="console.error('Image failed to load:', this.src)">
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 min-h-screen flex items-center">
        <div class="max-w-3xl">
            <h1
                class="text-4xl sm:text-5xl md:text-6xl font-bold mb-4 sm:mb-6 text-blue-700 leading-tight animate-fade-in">
                WELCOME TO MEDILAB
            </h1>
            <p class="text-lg sm:text-xl md:text-2xl mb-6 sm:mb-8 text-blue-700/90 max-w-2xl animate-fade-in-delay">
                Your trusted healthcare companion. Empowering better health through innovative medical solutions.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-delay-2">
                <a href="/services"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-6 sm:px-8 py-3 rounded-full font-semibold transition duration-300 text-center">
                    Our Services
                </a>
                <a href="/contact"
                    class="bg-white hover:bg-gray-100 text-blue-900 px-6 sm:px-8 py-3 rounded-full font-semibold transition duration-300 text-center shadow-md">
                    Contact Us
                </a>
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10 animate-bounce hidden md:block">
        <i class="fas fa-chevron-down text-blue-600 text-2xl"></i>
    </div>
</section>

<style>
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in {
        animation: fadeIn 0.8s ease-out forwards;
    }

    .animate-fade-in-delay {
        animation: fadeIn 0.8s ease-out 0.3s forwards;
        opacity: 0;
    }

    .animate-fade-in-delay-2 {
        animation: fadeIn 0.8s ease-out 0.6s forwards;
        opacity: 0;
    }
</style>

