            }

            .pagination .page-item.active .page-link {
                background: #667eea;
                border-color: #667eea;
                color: white;
            }

            .pagination .page-link:hover {
                background: #f5f5f5;
                border-color: #e0e0e0;
            }

            /* Empty State */
            .empty-state {
                text-align: center;
                padding: 4rem 2rem;
            }

            .empty-icon {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                background: #f5f5f5;
                display: flex;
                align-items: center;
