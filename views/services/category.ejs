                font-weight: 500;
            }

            .location-section {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                font-size: 0.9rem;
                color: #666;
            }

            .location-section i {
                color: #667eea;
            }

            .card-footer-section {
                padding: 1.25rem;
                border-top: 1px solid #f0f0f0;
            }

            /* Pagination */
            .pagination .page-link {
                border: 1px solid #e0e0e0;
                color: #666;
                border-radius: 8px;
                margin: 0 0.25rem;
