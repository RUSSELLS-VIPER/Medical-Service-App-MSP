<!-- Hero Section -->
<section class="hero-gradient position-relative overflow-hidden">
    <div class="container py-5">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-transparent">
                <li class="breadcrumb-item"><a href="/"
                        class="text-white text-decoration-none opacity-75 hover-opacity-100">Home</a></li>
                <li class="breadcrumb-item"><a href="/services"
                        class="text-white text-decoration-none opacity-75 hover-opacity-100">Services</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">
                    <%= category.name %>
                </li>
            </ol>
        </nav>

        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-4 fw-bold text-white mb-3">
                    <%= category.name %>
                </h1>
                <% if (category.description) { %>
                    <p class="lead text-white opacity-90 mb-4">
                        <%= category.description %>
                    </p>
                    <% } %>

                        <div class="d-flex flex-wrap gap-4 mb-4">
                            <div class="stat-card">
                                <div class="stat-number">
                                    <%= stats.totalServices %>
                                </div>
                                <div class="stat-label">Services</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-number">
                                    <%= stats.totalProviders %>
                                </div>
                                <div class="stat-label">Providers</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-number">
                                    <%= stats.averageRating %>
                                </div>
                                <div class="stat-label">Avg Rating</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-number">
                                    <%= stats.totalReviews %>
                                </div>
                                <div class="stat-label">Reviews</div>
                            </div>
                        </div>
            </div>
        </div>
    </div>
</section>

<!-- Controls Bar -->
<section class="controls-bar bg-white border-bottom sticky-top">
    <div class="container">
        <div class="row align-items-center py-3">
            <div class="col-md-6 mb-3 mb-md-0">
                <h5 class="mb-0 fw-semibold">
                    <%= pagination.totalItems %> <span class="text-muted fw-normal">Providers Found</span>
                </h5>
            </div>
            <div class="col-md-6">
                <div class="d-flex gap-2 justify-content-md-end flex-wrap">
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle" type="button"
                            data-bs-toggle="dropdown">
                            Sort: <%= sortOptions.find(opt=> opt.value === currentSort)?.label || 'Default' %>
                        </button>
                        <ul class="dropdown-menu">
                            <% sortOptions.forEach(function(option) { %>
                                <li>
                                    <a class="dropdown-item <%= option.value === currentSort ? 'active' : '' %>"
                                        href="?sort=<%= option.value %>&page=1">
                                        <%= option.label %>
                                    </a>
                                </li>
                                <% }) %>
                        </ul>
                    </div>

                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" name="view" id="gridView" checked>
                        <label class="btn btn-outline-secondary" for="gridView">
                            <i class="fas fa-grip"></i>
                        </label>
                        <input type="radio" class="btn-check" name="view" id="listView">
                        <label class="btn btn-outline-secondary" for="listView">
                            <i class="fas fa-list"></i>
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Grid -->
<section class="py-5 bg-light">
    <div class="container">
        <% if (services && services.length> 0) { %>
            <div class="row g-4" id="servicesGrid">
                <% services.forEach(function(service) { %>
                    <div class="col-lg-4 col-md-6">
                        <div class="service-card">
                            <div class="card-header-section">
                                <div class="provider-info">
                                    <% if (service.provider.profileImage) { %>
                                        <img src="<%= service.provider.profileImage %>"
                                            alt="<%= service.provider.firstName %> <%= service.provider.lastName %>"
                                            class="provider-avatar">
                                        <% } else { %>
                                            <div class="provider-avatar-placeholder">
                                                <i class="fas fa-user-md"></i>
                                            </div>
                                            <% } %>
                                                <div class="provider-details">
                                                    <h6 class="provider-name">
                                                        <%= service.provider.professionalTitle %>
                                                            <%= service.provider.firstName %>
                                                                <%= service.provider.lastName %>
                                                    </h6>
                                                    <p class="provider-specialty">
                                                        <%= service.provider.specialization %>
                                                    </p>
                                                </div>
                                </div>

                             
                            </div>

                            <div class="card-body-section">
                                <h5 class="service-title">
                                    <%= service.name || service.serviceName %>
                                </h5>
                                <% if (service.description || service.shortDescription) { %>
                                    <p class="service-description">
                                        <%= service.description || service.shortDescription %>
                                    </p>
                                    <% } %>

                                        <div class="service-meta">
                                            <div class="meta-item">
                                                <i class="fas fa-clock"></i>
                                                <span>
                                                    <%= service.duration || 60 %> min
                                                </span>
                                            </div>
                                            <% if (service.price || service.basePrice) { %>
                                                <div class="meta-item">
                                                    <i class="fas fa-rupee-sign"></i>
                                                    <span>
                                                        <%= service.price || service.basePrice %>
                                                    </span>
                                                </div>
                                                <% } %>
                                                    <div class="meta-item">
                                                        <span
                                                            class="badge <%= service.isVirtual ? 'badge-virtual' : 'badge-inperson' %>">
                                                            <%= service.isVirtual ? 'Virtual' : 'In-Person' %>
                                                        </span>
                                                    </div>
                                        </div>

                                        <% if (service.provider.location && service.provider.location.city) { %>
                                            <div class="location-section">
                                                <i class="fas fa-map-marker-alt"></i>
                                                <span>
                                                    <%= service.provider.location.city %>
                                                        <%= service.provider.location.state ? ', ' +
                                                            service.provider.location.state : '' %>
                                                </span>
                                            </div>
                                            <% } %>
                            </div>

                            <div class="card-footer-section">
                                <% if (user && user.role==='patient' ) { %>
                                    <button class="btn btn-primary w-100 mb-2"
                                        onclick="openBooking('<%= service._id %>', '<%= service.name || service.serviceName %>', '<%= service.duration || 60 %>', '<%= service.provider.firstName %> <%= service.provider.lastName %>')">
                                        <i class="fas fa-calendar-check me-2"></i>Book Appointment
                                    </button>
                                    <% } else { %>
                                        <a href="/auth/patient/login" class="btn btn-primary w-100 mb-2">
                                            <i class="fas fa-sign-in-alt me-2"></i>Login to Book
                                        </a>
                                        <% } %>
                                            <button class="btn btn-outline-secondary w-100"
                                                onclick="viewProviderProfile('<%= service.provider._id %>')">
                                                View Profile
                                            </button>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>

            <!-- Pagination -->
            <% if (pagination.totalPages> 1) { %>
                <nav class="mt-5" aria-label="Pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item <%= !pagination.hasPrev ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= pagination.currentPage - 1 %>&sort=<%= currentSort %>">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        <% const startPage=Math.max(1, pagination.currentPage - 2); %>
                            <% const endPage=Math.min(pagination.totalPages, pagination.currentPage + 2); %>

                                <% if (startPage> 1) { %>
                                    <li class="page-item"><a class="page-link"
                                            href="?page=1&sort=<%= currentSort %>">1</a></li>
                                    <% if (startPage> 2) { %>
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                        <% } } %>

                                            <% for (let i=startPage; i <=endPage; i++) { %>
                                                <li
                                                    class="page-item <%= i === pagination.currentPage ? 'active' : '' %>">
                                                    <a class="page-link" href="?page=<%= i %>&sort=<%= currentSort %>">
                                                        <%= i %>
                                                    </a>
                                                </li>
                                                <% } %>

                                                    <% if (endPage < pagination.totalPages) { %>
                                                        <% if (endPage < pagination.totalPages - 1) { %>
                                                            <li class="page-item disabled"><span
                                                                    class="page-link">...</span></li>
                                                            <% } %>
                                                                <li class="page-item"><a class="page-link"
                                                                        href="?page=<%= pagination.totalPages %>&sort=<%= currentSort %>">
                                                                        <%= pagination.totalPages %>
                                                                    </a></li>
                                                                <% } %>

                                                                    <li
                                                                        class="page-item <%= !pagination.hasNext ? 'disabled' : '' %>">
                                                                        <a class="page-link"
                                                                            href="?page=<%= pagination.currentPage + 1 %>&sort=<%= currentSort %>">
                                                                            <i class="fas fa-chevron-right"></i>
                                                                        </a>
                                                                    </li>
                    </ul>
                    <div class="text-center mt-3">
                        <small class="text-muted">
                            Showing <%= ((pagination.currentPage - 1) * pagination.itemsPerPage) + 1 %> to <%=
                                    Math.min(pagination.currentPage * pagination.itemsPerPage, pagination.totalItems) %>
                                    of <%= pagination.totalItems %> results
                        </small>
                    </div>
                </nav>
                <% } %>

                    <% } else { %>
                        <!-- Empty State -->
                        <div class="empty-state">
                            <div class="empty-icon">
                                <i class="fas fa-search"></i>
                            </div>
                            <h4>No Services Available</h4>
                            <p>We couldn't find any services in the <%= category.name %> category at the moment.</p>
                            <a href="/services" class="btn btn-primary mt-3">
                                <i class="fas fa-arrow-left me-2"></i>Browse All Services
                            </a>
                        </div>
                        <% } %>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="container text-center text-white">
        <h3 class="fw-bold mb-3">Need Assistance?</h3>
        <p class="lead mb-4 opacity-90">Our team is ready to help you find the right healthcare provider</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/contact" class="btn btn-light btn-lg">
                <i class="fas fa-phone me-2"></i>Contact Support
            </a>
            <a href="/services" class="btn btn-outline-light btn-lg">
                <i class="fas fa-search me-2"></i>All Services
            </a>
        </div>
    </div>
</section>

<!-- Booking Modal -->
<% if (user && user.role==='patient' ) { %>
    <div class="modal fade" id="bookingModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-calendar-check me-2"></i>Book Appointment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="bookingForm">
                        <input type="hidden" id="bookingServiceId" name="serviceId">

                        <div class="booking-info mb-4">
                            <div class="info-row">
                                <strong>Service:</strong> <span id="bookingServiceName"></span>
                            </div>
                            <div class="info-row">
                                <strong>Provider:</strong> <span id="bookingProviderName"></span>
                            </div>
                            <div class="info-row">
                                <strong>Duration:</strong> <span id="bookingServiceDuration"></span> min
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Date</label>
                                <input type="date" class="form-control" id="bookingDate" name="date" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Time</label>
                                <select class="form-select" id="bookingTime" name="time" required>
                                    <option value="">Select time</option>
                                    <option value="09:00">9:00 AM</option>
                                    <option value="10:00">10:00 AM</option>
                                    <option value="11:00">11:00 AM</option>
                                    <option value="14:00">2:00 PM</option>
                                    <option value="15:00">3:00 PM</option>
                                    <option value="16:00">4:00 PM</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Notes (Optional)</label>
                                <textarea class="form-control" id="bookingNotes" name="notes" rows="3"
                                    placeholder="Any specific requirements..."></textarea>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="submitBooking()">Confirm Booking</button>
                </div>
            </div>
        </div>
    </div>
    <% } %>

        <style>
            /* Hero Section */
            .hero-gradient {
                background: linear-gradient(135deg, rgba(0, 0, 0, 0.662) 0%),
                    url('/assets/images/hero-services.jpg') center/cover no-repeat;
                min-height: 320px;
                color: white;
            }

            .hover-opacity-100:hover {
                opacity: 1 !important;
            }

            .stat-card {
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(10px);
                border-radius: 12px;
                padding: 1rem 1.5rem;
                text-align: center;
            }

            .stat-number {
                font-size: 1.75rem;
                font-weight: 700;
                color: white;
            }

            .stat-label {
                font-size: 0.85rem;
                color: rgba(255, 255, 255, 0.85);
                margin-top: 0.25rem;
            }

            /* Controls Bar */
            .controls-bar {
                z-index: 1000;
                top: 0;
            }

            /* Service Cards */
            .service-card {
                background: white;
                border-radius: 16px;
                overflow: hidden;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
                transition: all 0.3s ease;
                height: 100%;
                display: flex;
                flex-direction: column;
            }

            .service-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
            }

            .card-header-section {
                padding: 1.25rem;
                border-bottom: 1px solid #f0f0f0;
            }

            .provider-info {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                margin-bottom: 1rem;
            }

            .provider-avatar {
                width: 56px;
                height: 56px;
                border-radius: 50%;
                object-fit: cover;
            }

            .provider-avatar-placeholder {
                width: 56px;
                height: 56px;
                border-radius: 50%;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 1.5rem;
            }

            .provider-name {
                margin: 0;
                font-size: 0.95rem;
                font-weight: 600;
                color: #1a1a1a;
            }

            .provider-specialty {
                margin: 0;
                font-size: 0.85rem;
                color: #666;
            }

            .rating-section {
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            .rating-stars i {
                font-size: 0.85rem;
                color: #e0e0e0;
            }

            .rating-stars i.active {
                color: #ffc107;
            }

            .rating-text {
                font-size: 0.85rem;
                color: #666;
            }

            .card-body-section {
                padding: 1.25rem;
                flex-grow: 1;
            }

            .service-title {
                font-size: 1.1rem;
                font-weight: 600;
                color: #1a1a1a;
                margin-bottom: 0.75rem;
            }

            .service-description {
                font-size: 0.9rem;
                color: #666;
                margin-bottom: 1rem;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .service-meta {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                margin-bottom: 1rem;
            }

            .meta-item {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                font-size: 0.9rem;
                color: #666;
            }

            .meta-item i {
                color: #667eea;
            }

            .badge-virtual {
                background: #e3f2fd;
                color: #1976d2;
                padding: 0.25rem 0.75rem;
                border-radius: 20px;
                font-weight: 500;
            }

            .badge-inperson {
                background: #e8f5e9;
                color: #388e3c;
                padding: 0.25rem 0.75rem;
