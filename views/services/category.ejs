            }

            .empty-state p {
                color: #666;
            }

            /* CTA Section */
            .cta-section {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                padding: 4rem 0;
            }

            /* Booking Modal */
            .booking-info {
                background: #f8f9fa;
                border-radius: 8px;
                padding: 1rem;
            }

            .info-row {
                margin-bottom: 0.5rem;
            }

            .info-row:last-child {
                margin-bottom: 0;
            }

            /* Responsive */
            @media (max-width: 768px) {
                .stat-card {
                    flex: 0 0 calc(50% - 0.5rem);
                }

                .controls-bar .col-md-6 {
                    text-align: center;
                }
            }
        </style>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const today = new Date().toISOString().split('T')[0];
                const bookingDateInput = document.getElementById('bookingDate');
                if (bookingDateInput) {
                    bookingDateInput.setAttribute('min', today);
                }

                // View toggle
                const gridView = document.getElementById('gridView');
                const listView = document.getElementById('listView');
                const servicesGrid = document.getElementById('servicesGrid');

                if (gridView && listView && servicesGrid) {
                    listView.addEventListener('change', function () {
                        if (this.checked) {
                            servicesGrid.querySelectorAll('.col-lg-4').forEach(col => {
                                col.className = 'col-12';
                            });
                        }
                    });

                    gridView.addEventListener('change', function () {
                        if (this.checked) {
                            servicesGrid.querySelectorAll('.col-12').forEach(col => {
                                col.className = 'col-lg-4 col-md-6';
                            });
                        }
                    });
                }
            });

            function openBooking(serviceId, serviceName, serviceDuration, providerName) {
                document.getElementById('bookingServiceId').value = serviceId;
                document.getElementById('bookingServiceName').textContent = serviceName;
                document.getElementById('bookingServiceDuration').textContent = serviceDuration;
                document.getElementById('bookingProviderName').textContent = providerName;
                new bootstrap.Modal(document.getElementById('bookingModal')).show();
            }

            function viewProviderProfile(providerId) {
                window.location.href = '/providers/' + providerId;
            }

            async function submitBooking() {
                const form = document.getElementById('bookingForm');
                const formData = new FormData(form);
                const data = Object.fromEntries(formData);

                try {
                    const response = await fetch('/api/patient/appointments', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });

                    const result = await response.json();

                    if (result.success) {
                        alert('Appointment booked successfully!');
                        bootstrap.Modal.getInstance(document.getElementById('bookingModal')).hide();
                        form.reset();
                    } else {
                        alert('Failed to book appointment: ' + (result.message || 'Unknown error'));
                    }
                } catch (error) {
                    console.error('Booking error:', error);
                    alert('An error occurred while booking the appointment');
                }
            }
        </script>