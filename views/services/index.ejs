<% /* Redesigned Services Page: Clean, modern, and accessible layout */ %>
    <style>
        /* Modern CSS Variables */
        :root {
            --primary-blue: #04243a;
            --primary-light: #667eea;
            --accent-purple: #f093fb;
            --accent-blue: #4facfe;
            --accent-green: #43e97b;
            --accent-pink: #fa709a;
            --accent-teal: #a8edea;
            --gray-light: #f8fafc;
            --gray-medium: #64748b;
            --shadow-light: 0 4px 20px rgba(0, 0, 0, 0.08);
            --shadow-hover: 0 12px 40px rgba(0, 0, 0, 0.12);
            --border-radius: 16px;
            --border-radius-sm: 12px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Hero Section */
        .services-hero {
            background:
                linear-gradient(135deg, rgba(0, 0, 0, 0.777) 0%, rgba(102, 126, 234, 0) 100%),
                url('/assets/images/hero-services.jpg') center/cover no-repeat;
            padding: 4rem 0;
            margin-bottom: 2rem;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .services-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            opacity: 0.3;
        }

        .services-hero .container {
            position: relative;
            z-index: 2;
        }

        .services-hero h1 {
            font-weight: 800;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #ffffff 0%, #e2e8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .services-hero p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 1.1rem;
            margin-bottom: 2rem;
        }

        /* Quick Stats */
        .quick-stats {
            gap: 1rem;
        }

        .quick-stats>div {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: var(--border-radius-sm);
            padding: 1.25rem;
            min-width: 120px;
            transition: var(--transition);
        }

        .quick-stats>div:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: translateY(-2px);
        }

        .quick-stats .small {
            color: rgba(255, 255, 255, 0.8);
            font-weight: 500;
        }

        .quick-stats .fw-bold {
            color: white;
            font-size: 1.5rem;
            font-weight: 700;
        }

        /* Search Bar */
        .search-bar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: var(--border-radius);
            padding: 1rem;
            box-shadow: var(--shadow-light);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .search-bar .form-control {
            border-radius: 50px 0 0 50px;
            border: none;
            box-shadow: none;
            padding: 0.75rem 1.5rem;
            font-size: 1rem;
            background: var(--gray-light);
        }

        .search-bar .form-control:focus {
            background: white;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .search-bar .btn-search {
            border-radius: 0 50px 50px 0;
            border: none;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
            background: linear-gradient(135deg, var(--primary-light), var(--primary-blue));
            transition: var(--transition);
        }

        .search-bar .btn-search:hover {
            transform: translateX(2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        /* Category Filter Pills */
        .pill-filter {
            margin-top: 1.5rem;
        }

        .pill-filter .btn {
            border-radius: 50px;
            padding: 0.5rem 1.25rem;
            font-weight: 500;
            border: 2px solid rgba(255, 255, 255, 0.3);
            color: white;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            transition: var(--transition);
            margin: 0.25rem;
        }

        .pill-filter .btn:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.5);
            transform: translateY(-2px);
        }

        /* Category Grid */
        .category-grid .card {
            border: none;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow-light);
            transition: var(--transition);
            background: white;
            overflow: hidden;
            height: 100%;
        }

        .category-grid .card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-hover);
        }

        .category-grid .card-body {
            padding: 1.5rem;
        }

        .icon-container {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, var(--gray-light), #e2e8f0);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--border-radius-sm);
            transition: var(--transition);
        }

        .category-grid .card:hover .icon-container {
            transform: scale(1.1) rotate(5deg);
        }

        .icon-container i {
            font-size: 1.5rem;
        }

        .category-grid h5 {
            color: var(--primary-blue);
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .category-grid .text-muted {
            color: var(--gray-medium) !important;
            line-height: 1.5;
        }

        .category-grid .btn-outline-primary {
            border-radius: 50px;
            padding: 0.375rem 1.25rem;
            font-weight: 600;
            border-width: 2px;
            transition: var(--transition);
        }

        .category-grid .btn-outline-primary:hover {
            transform: translateX(4px);
        }

        /* Modal Styles */
        .modal-content {
            border-radius: var(--border-radius);
            border: none;
            box-shadow: var(--shadow-hover);
        }

        .modal-header {
            border-bottom: 1px solid #e2e8f0;
            padding: 1.5rem;
        }

        .modal-title {
            color: var(--primary-blue);
            font-weight: 700;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            border-top: 1px solid #e2e8f0;
            padding: 1.5rem;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .services-hero {
                padding: 2.5rem 0;
                text-align: center;
            }

            .services-hero h1 {
                font-size: 2rem;
            }

            .quick-stats {
                justify-content: center;
            }

            .search-bar {
                margin-top: 1.5rem;
            }

            .pill-filter {
                text-align: center;
            }

            .category-grid .col-lg-4 {
                margin-bottom: 1rem;
            }
        }

        @media (max-width: 576px) {
            .services-hero {
                padding: 2rem 0;
            }

            .search-bar .form-control {
                padding: 0.625rem 1.25rem;
            }

            .search-bar .btn-search {
                padding: 0.625rem 1.25rem;
            }

            .icon-container {
                width: 60px;
                height: 60px;
            }

            .icon-container i {
                font-size: 1.25rem;
            }
        }

        /* Animation for cards */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .category-grid .card {
            animation: fadeInUp 0.6s ease-out;
        }

        .category-grid .card:nth-child(2) {
            animation-delay: 0.1s;
        }

        .category-grid .card:nth-child(3) {
            animation-delay: 0.2s;
        }

        .category-grid .card:nth-child(4) {
            animation-delay: 0.3s;
        }

        .category-grid .card:nth-child(5) {
            animation-delay: 0.4s;
        }

        .category-grid .card:nth-child(6) {
            animation-delay: 0.5s;
        }
    </style>

    <!-- Hero / Search Section -->
    <section class="services-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <h1 class="display-5 fw-bold mb-3">Find Medical Services & Appointments</h1>
                    <p class="lead opacity-90 mb-4">Discover trusted healthcare providers, book appointments seamlessly,
                        and get the care you deserve.</p>
                    <div class="mt-4 d-flex quick-stats">
                        <div class="stat-card">
                            <div class="small text-white-80">Services Available</div>
                            <div class="fw-bold">
                                <%= totalServices || 0 %>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="small text-white-80">Verified Providers</div>
                            <div class="fw-bold">
                                <%= totalProviders || 0 %>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">

                    <div class="pill-filter mt-3">
                        <% (serviceCategories || categories || []).slice(0,6).forEach(function(cat, index){ %>
                            <button class="btn btn-pill" onclick="filterByCategory('<%= cat._id %>')">
                                <i class="fas <%= cat.icon || 'fa-star' %> me-1"></i>
                                <%= cat.name %>
                            </button>
                            <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Category Grid -->
    <section class="container category-grid mb-5">
        <div class="row g-4">
            <% (serviceCategories || categories || []).forEach(function(cat, index){ %>
                <div class="col-xl-4 col-lg-6 col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-start">
                                <div class="icon-container me-3">
                                    <% const
                                        defaultIcons=['fa-stethoscope','fa-heart-pulse','fa-tooth','fa-eye','fa-user-doctor','fa-truck-medical','fa-brain','fa-lungs'];
                                        %>
                                        <% const iconClass=cat.icon && cat.icon.length ? cat.icon : defaultIcons[index %
                                            defaultIcons.length]; %>
                                            <% const iconColor=cat.color ||
                                                (['#667eea','#f093fb','#4facfe','#43e97b','#fa709a','#a8edea','#ffd166','#06d6a0'][index
                                                % 8]); %>
                                                <i class="fas <%= iconClass %>" style="color: <%= iconColor %>;"
                                                    aria-hidden="true"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mb-2">
                                        <%= cat.name %>
                                    </h5>
                                    <p class="text-muted small mb-3">
                                        <%= (cat.shortDescription || cat.description
                                            || 'Comprehensive healthcare services' ).slice(0,120) %>...
                                    </p>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="badge bg-light text-dark">
                                    <i class="fas fa-procedures me-1"></i>
                                    <%= (servicesByCategory && servicesByCategory[cat._id]) ?
                                        (servicesByCategory[cat._id].services.length || 0) : 0 %> Services
                                </span>
                                <a href="/services/category/<%= cat._id %>" class="btn btn-outline-primary btn-sm">
                                    Explore <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>
    </section>

    <!-- Booking Modal (Preserved for patients) -->
    <% if (user && user.role==='patient' ) { %>
        <div class="modal fade" id="bookingModal" tabindex="-1" aria-labelledby="bookingModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="bookingModalLabel">
                            <i class="fas fa-calendar-plus me-2 text-primary"></i>Book Your Appointment
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="bookingForm">
                            <input type="hidden" id="bookingServiceId" name="serviceId">
                            <div class="mb-4">
                                <div class="alert alert-info border-0 rounded-3">
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-info-circle me-2 text-primary"></i>
                                        <div>
                                            <strong class="d-block">Service Details</strong>
                                            <span id="bookingServiceName" class="fw-bold text-dark"></span> •
                                            <span id="bookingServiceDuration" class="text-muted"></span> minutes
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="bookingDate" class="form-label fw-semibold">Preferred Date</label>
                                    <input type="date" class="form-control rounded-2" id="bookingDate" name="date"
                                        required>
                                </div>
                                <div class="col-md-6">
                                    <label for="bookingTime" class="form-label fw-semibold">Preferred Time</label>
                                    <select class="form-select rounded-2" id="bookingTime" name="time" required>
                                        <option value="">Select time...</option>
                                        <option value="09:00">9:00 AM</option>
                                        <option value="10:00">10:00 AM</option>
                                        <option value="11:00">11:00 AM</option>
                                        <option value="14:00">2:00 PM</option>
                                        <option value="15:00">3:00 PM</option>
                                        <option value="16:00">4:00 PM</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label for="bookingNotes" class="form-label fw-semibold">Additional Notes</label>
                                    <textarea class="form-control rounded-2" id="bookingNotes" name="notes" rows="3"
                                        placeholder="Any specific symptoms, requirements, or notes for the doctor..."></textarea>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary rounded-2 px-4"
                            data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary rounded-2 px-4" onclick="submitBooking()">
                            <i class="fas fa-calendar-check me-2"></i>Confirm Booking
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const today = new Date().toISOString().split('T')[0];
                const bookingDate = document.getElementById('bookingDate');
                if (bookingDate) bookingDate.setAttribute('min', today);
            });

            function openBooking(serviceId, serviceName, serviceDuration) {
                document.getElementById('bookingServiceId').value = serviceId;
                document.getElementById('bookingServiceName').textContent = serviceName;
                document.getElementById('bookingServiceDuration').textContent = serviceDuration;
                const modal = new bootstrap.Modal(document.getElementById('bookingModal'));
                modal.show();
            }

            async function submitBooking() {
                const form = document.getElementById('bookingForm');
                const formData = new FormData(form);
                const data = Object.fromEntries(formData);

                try {
                    const response = await fetch('/api/patient/appointments', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await response.json();

                    if (result.success) {
                        // Show success message
                        alert('🎉 Appointment booked successfully!');
                        bootstrap.Modal.getInstance(document.getElementById('bookingModal')).hide();
                        form.reset();
                    } else {
                        alert('❌ Failed to book appointment: ' + (result.message || 'Unknown error'));
                    }
                } catch (error) {
                    console.error('Booking error:', error);
                    alert('⚠️ An error occurred while booking the appointment');
                }
            }
        </script>
        <% } %>

            <script>
                // Enhanced search functionality
                document.getElementById('serviceSearchBtn').addEventListener('click', performSearch);
                document.getElementById('serviceSearchInput').addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') performSearch();
                });

                function performSearch() {
                    const query = document.getElementById('serviceSearchInput').value.trim();
                    if (!query) return;

                    // Add loading state
                    const btn = document.getElementById('serviceSearchBtn');
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                    btn.disabled = true;

                    setTimeout(() => {
                        window.location.href = '/services?search=' + encodeURIComponent(query);
                    }, 500);
                }

                function filterByCategory(catId) {
                    if (!catId) return;
                    window.location.href = '/services/category/' + catId;
                }
            </script>