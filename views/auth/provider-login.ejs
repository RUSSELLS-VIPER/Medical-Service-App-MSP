<section class="py-5" style="margin-top: 90px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-8 col-lg-6">
                <div class="card shadow-sm rounded-4 overflow-hidden">
                    <div class="p-4 text-center">
                        <h2 class="h4 mb-1">Provider Login</h2>
                        <p class="text-muted mb-0">Access your provider dashboard</p>
                    </div>
                    <div class="card-body p-4">
                        <% if (error && error.length> 0) { %>
                            <div class="alert alert-danger">
                                <%= error %>
                            </div>
                            <% } %>
                                <form action="/auth/provider/login" method="POST">
                                    <div class="mb-3">
                                        <label for="email" class="form-label">Email</label>
                                        <input type="email" id="email" name="email" class="form-control" required
                                            value="provider@msp.com">
                                    </div>
                                    <div class="mb-3">
                                        <label for="password" class="form-label">Password</label>
                                        <input type="password" id="password" name="password" class="form-control"
                                            required value="provider@msp.com">
                                    </div>
                                    <button type="submit" class="btn btn-success w-100">Login as Provider</button>
                                </form>
                                <div class="text-center mt-3">
                                    <p class="text-muted mb-0">Don't have an account? <a
                                            href="/register/provider">Register here</a></p>
                                </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>