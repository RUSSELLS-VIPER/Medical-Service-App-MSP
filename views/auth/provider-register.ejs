<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Healthcare Provider Registration</title>

    <!-- Custom fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@200;300;400;600;700;800;900&display=swap"
        rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#667eea',
                        secondary: '#764ba2',
                        accent: '#5a67d8',
                        light: '#f8f9fa',
                        dark: '#2c3e50'
                    }
                }
            }
        }
    </script>

    <style>
        :root {
            --primary-color: #4e73df;
            --success-color: #1cc88a;
            --info-color: #36b9cc;
            --warning-color: #f6c23e;
            --danger-color: #e74a3b;
            --secondary-color: #858796;
            --light-color: #f8f9fc;
            --dark-color: #5a5c69;
        }

        body {
            font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: var(--light-color) !important;
        }

        .card {
            border: none;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
            transition: all 0.3s ease;
        }

        .card:hover {
            transform: translateY(-2px);
        }

        .password-strength {
            height: 4px;
            border-radius: 2px;
            background: #e9ecef;
            overflow: hidden;
        }

        .password-strength::before {
            content: '';
            display: block;
            height: 100%;
            width: 0;
            transition: width 0.3s ease, background-color 0.3s ease;
        }

        .password-strength.weak::before {
            width: 25%;
            background: #dc3545;
        }

        .password-strength.medium::before {
            width: 50%;
            background: #ffc107;
        }

        .password-strength.strong::before {
            width: 75%;
            background: #28a745;
        }

        .password-strength.very-strong::before {
            width: 100%;
            background: #20c997;
        }

        .service-category-card.selected::before {
            content: '✓';
            position: absolute;
            top: 10px;
            right: 10px;
            width: 25px;
            height: 25px;
            background: #28a745;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 14px;
        }

        .selected-service-tag .remove-service {
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container py-5">
        <!-- Header Section -->
        <div class="text-center mb-5">
            <div class="card shadow mb-4">
                <div class="card-body py-5">
                    <i class="fas fa-user-md fa-3x text-primary mb-3"></i>
                    <h1 class="h2 mb-2">Healthcare Provider Registration</h1>
                    <p class="text-muted lead">Join our network of trusted healthcare professionals</p>
                </div>
            </div>
        </div>

        <!-- Main Registration Form -->
        <div class="card shadow">
            <div class="card-body p-4">
                <form action="/auth/register/provider" method="POST" enctype="multipart/form-data"
                    id="providerRegisterForm">
                    <!-- Hidden input to track selected services count -->
                    <input type="hidden" id="selectedServicesCount" name="selectedServicesCount" value="0">

                    <!-- Personal Information Section -->
                    <div class="mb-8 pb-6 border-b border-gray-200">
                        <div class="flex items-center mb-6">
                            <div
                                class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl flex items-center justify-center text-white text-xl mr-4">
                                <i class="fas fa-user"></i>
                            </div>
                            <h3 class="text-xl font-semibold text-dark">Personal Information</h3>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="firstName" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-user-circle me-2 text-primary"></i>First Name
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="firstName" name="firstName" placeholder="Enter your first name" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="lastName" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-user-circle me-2 text-primary"></i>Last Name
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="lastName" name="lastName" placeholder="Enter your last name" required>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4 mt-2">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="email" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-envelope me-2 text-primary"></i>Email Address
                                    </label>
                                    <input type="email"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="email" name="email" placeholder="your.email@example.com" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="phone" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-phone me-2 text-primary"></i>Phone Number
                                    </label>
                                    <input type="tel"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="phone" name="phone" placeholder="+1 (555) 123-4567" required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Security Section -->
                    <div class="mb-8 pb-6 border-b border-gray-200">
                        <div class="flex items-center mb-6">
                            <div
                                class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl flex items-center justify-center text-white text-xl mr-4">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <h3 class="text-xl font-semibold text-dark">Account Security</h3>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="password" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-lock me-2 text-primary"></i>Password
                                    </label>
                                    <div class="position-relative">
                                        <input type="password"
                                            class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                            id="password" name="password" placeholder="Create a strong password"
                                            required minlength="8">
                                        <button type="button"
                                            class="position-absolute top-3 end-3 text-gray-500 hover:text-primary transition"
                                            onclick="togglePassword('password')">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    <div class="password-strength mt-2" id="passwordStrength"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="confirmPassword" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-lock me-2 text-primary"></i>Confirm Password
                                    </label>
                                    <div class="position-relative">
                                        <input type="password"
                                            class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                            id="confirmPassword" name="confirmPassword"
                                            placeholder="Confirm your password" required>
                                        <button type="button"
                                            class="position-absolute top-3 end-3 text-gray-500 hover:text-primary transition"
                                            onclick="togglePassword('confirmPassword')">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Professional Information Section -->
                    <div class="mb-8 pb-6 border-b border-gray-200">
                        <div class="flex items-center mb-6">
                            <div
                                class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl flex items-center justify-center text-white text-xl mr-4">
                                <i class="fas fa-stethoscope"></i>
                            </div>
                            <h3 class="text-xl font-semibold text-dark">Professional Information</h3>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="professionalTitle" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-user-md me-2 text-primary"></i>Professional Title
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="professionalTitle" name="professionalTitle"
                                        placeholder="e.g., Dr., Nurse Practitioner, Specialist" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="specialization" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-heartbeat me-2 text-primary"></i>Specialization
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="specialization" name="specialization"
                                        placeholder="e.g., Cardiology, Pediatrics, Internal Medicine" required>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4 mt-2">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="yearsOfExperience" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-clock me-2 text-primary"></i>Years of Experience
                                    </label>
                                    <input type="number"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="yearsOfExperience" name="yearsOfExperience" placeholder="0" min="0" max="50"
                                        required>
                                    <div class="form-text text-gray-500">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Enter your total years of professional experience
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="licenseNumber" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-id-card me-2 text-primary"></i>License Number
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="licenseNumber" name="licenseNumber"
                                        placeholder="Enter your professional license number" required>
                                    <div class="form-text text-gray-500">
                                        <i class="fas fa-shield-alt me-1"></i>
                                        Your license will be verified during the approval process
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Additional Professional Information -->
                        <div class="row g-4 mt-2">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="additionalInfo" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-info-circle me-2 text-primary"></i>Additional Professional
                                        Information
                                    </label>
                                    <textarea
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="additionalInfo" name="additionalInfo" rows="3"
                                        placeholder="Tell us about your qualifications, certifications, or any additional information that would help patients understand your expertise..."></textarea>
                                    <div class="form-text text-gray-500">
                                        <i class="fas fa-lightbulb me-1"></i>
                                        Optional: Share additional qualifications, certifications, or specializations
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Location & Practice Information Section -->
                    <div class="mb-8 pb-6 border-b border-gray-200">
                        <div class="flex items-center mb-6">
                            <div
                                class="w-12 h-12 bg-gradient-to-br from-primary to-secondary rounded-xl flex items-center justify-center text-white text-xl mr-4">
                                <i class="fas fa-map-marker-alt"></i>
                            </div>
                            <h3 class="text-xl font-semibold text-dark">Location & Practice Information</h3>
                        </div>

                        <!-- Practice Information -->
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="practiceName" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-building me-2 text-primary"></i>Practice Name
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="practiceName" name="practiceName"
                                        placeholder="e.g., Downtown Medical Center">
                                    <div class="form-text text-gray-500">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Optional: Name of your medical practice or clinic
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="practiceType" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-hospital me-2 text-primary"></i>Practice Type
                                    </label>
                                    <select
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="practiceType" name="practiceType">
                                        <option value="private">Private Practice</option>
                                        <option value="hospital">Hospital</option>
                                        <option value="clinic">Clinic</option>
                                        <option value="group_practice">Group Practice</option>
                                        <option value="telemedicine_only">Telemedicine Only</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Location Information -->
                        <div class="row g-4 mb-4">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="address" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-map-marker-alt me-2 text-primary"></i>Practice Address
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="address" name="address" placeholder="Enter your practice address">
                                    <div class="form-text text-gray-500">
                                        <i class="fas fa-map-pin me-1"></i>
                                        Street address of your practice location
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="city" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-city me-2 text-primary"></i>City
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="city" name="city" placeholder="Enter city">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="state" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-flag me-2 text-primary"></i>State
                                    </label>
                                    <select
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="state" name="state">
                                        <option value="">Select State</option>
                                        <option value="AL">Alabama</option>
                                        <option value="AK">Alaska</option>
                                        <option value="AZ">Arizona</option>
                                        <option value="AR">Arkansas</option>
                                        <option value="CA">California</option>
                                        <option value="CO">Colorado</option>
                                        <option value="CT">Connecticut</option>
                                        <option value="DE">Delaware</option>
                                        <option value="FL">Florida</option>
                                        <option value="GA">Georgia</option>
                                        <option value="HI">Hawaii</option>
                                        <option value="ID">Idaho</option>
                                        <option value="IL">Illinois</option>
                                        <option value="IN">Indiana</option>
                                        <option value="IA">Iowa</option>
                                        <option value="KS">Kansas</option>
                                        <option value="KY">Kentucky</option>
                                        <option value="LA">Louisiana</option>
                                        <option value="ME">Maine</option>
                                        <option value="MD">Maryland</option>
                                        <option value="MA">Massachusetts</option>
                                        <option value="MI">Michigan</option>
                                        <option value="MN">Minnesota</option>
                                        <option value="MS">Mississippi</option>
                                        <option value="MO">Missouri</option>
                                        <option value="MT">Montana</option>
                                        <option value="NE">Nebraska</option>
                                        <option value="NV">Nevada</option>
                                        <option value="NH">New Hampshire</option>
                                        <option value="NJ">New Jersey</option>
                                        <option value="NM">New Mexico</option>
                                        <option value="NY">New York</option>
                                        <option value="NC">North Carolina</option>
                                        <option value="ND">North Dakota</option>
                                        <option value="OH">Ohio</option>
                                        <option value="OK">Oklahoma</option>
                                        <option value="OR">Oregon</option>
                                        <option value="PA">Pennsylvania</option>
                                        <option value="RI">Rhode Island</option>
                                        <option value="SC">South Carolina</option>
                                        <option value="SD">South Dakota</option>
                                        <option value="TN">Tennessee</option>
                                        <option value="TX">Texas</option>
                                        <option value="UT">Utah</option>
                                        <option value="VT">Vermont</option>
                                        <option value="VA">Virginia</option>
                                        <option value="WA">Washington</option>
                                        <option value="WV">West Virginia</option>
                                        <option value="WI">Wisconsin</option>
                                        <option value="WY">Wyoming</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="zipCode" class="form-label fw-semibold text-dark">
                                        <i class="fas fa-mail-bulk me-2 text-primary"></i>ZIP Code
                                    </label>
                                    <input type="text"
                                        class="form-control border-2 border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:border-primary focus:ring-2 focus:ring-primary focus:ring-opacity-20 transition"
                                        id="zipCode" name="zipCode" placeholder="12345" pattern="[0-9]{5}(-[0-9]{4})?"
                                        maxlength="10">
                                </div>
                            </div>
                        </div>

                        <!-- Additional Practice Information -->
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="form-label fw-semibold text-dark">
                                        <i class="fas fa-language me-2 text-primary"></i>Languages Spoken
                                    </label>
                                    <div class="border-2 border-gray-200 rounded-xl p-3 bg-gray-50">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="langEnglish"
                                                name="languages" value="English" checked>
                                            <label class="form-check-label" for="langEnglish">English</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="langSpanish"
                                                name="languages" value="Spanish">
                                            <label class="form-check-label" for="langSpanish">Spanish</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="langFrench"
                                                name="languages" value="French">
                                            <label class="form-check-label" for="langFrench">French</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="langMandarin"
                                                name="languages" value="Mandarin">
                                            <label class="form-check-label" for="langMandarin">Mandarin</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="langOther"
                                                name="languages" value="Other">
                                            <label class="form-check-label" for="langOther">Other</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="form-label fw-semibold text-dark">
                                        <i class="fas fa-shield-alt me-2 text-primary"></i>Insurance Acceptance
                                    </label>
                                    <div class="border-2 border-gray-200 rounded-xl p-3 bg-gray-50">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="acceptsInsurance"
                                                name="acceptsInsurance" value="true">
                                            <label class="form-check-label" for="acceptsInsurance">I accept
                                                insurance</label>
                                        </div>
                                        <div class="mt-3" id="insuranceProviders" style="display: none;">
                                            <label class="form-label fw-semibold text-dark">Insurance Providers</label>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="insBlueCross"
                                                    name="insuranceProviders" value="Blue Cross Blue Shield">
                                                <label class="form-check-label" for="insBlueCross">Blue Cross Blue
                                                    Shield</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="insAetna"
                                                    name="insuranceProviders" value="Aetna">
                                                <label class="form-check-label" for="insAetna">Aetna</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="insCigna"
                                                    name="insuranceProviders" value="Cigna">
                                                <label class="form-check-label" for="insCigna">Cigna</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="insUnitedHealth"
                                                    name="insuranceProviders" value="UnitedHealthcare">
                                                <label class="form-check-label"
                                                    for="insUnitedHealth">UnitedHealthcare</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Location Map Preview -->
                        <div class="mt-4">
                            <div class="alert alert-info d-flex align-items-center" role="alert">
                                <i class="fas fa-info-circle me-3"></i>
                                <div>
                                    <strong>Location Information:</strong>
                                    <ul class="mb-0 mt-2">
                                        <li>Your location helps patients find you easily</li>
