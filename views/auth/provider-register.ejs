    <!-- jQuery + Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- JavaScript for enhanced functionality -->
    <script>
        // Password visibility toggle
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const toggle = input.parentElement.querySelector('button i');

            if (input.type === 'password') {
                input.type = 'text';
                toggle.classList.remove('fa-eye');
                toggle.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                toggle.classList.remove('fa-eye-slash');
                toggle.classList.add('fa-eye');
            }
        }

        // Password strength indicator
        document.getElementById('password').addEventListener('input', function () {
            const password = this.value;
            const strengthDiv = document.getElementById('passwordStrength');

            let strength = 0;
            if (password.length >= 8) strength++;
            if (/[a-z]/.test(password)) strength++;
            if (/[A-Z]/.test(password)) strength++;
            if (/[0-9]/.test(password)) strength++;
            if (/[^A-Za-z0-9]/.test(password)) strength++;

            strengthDiv.className = 'password-strength';
            if (strength <= 2) strengthDiv.classList.add('weak');
            else if (strength <= 3) strengthDiv.classList.add('medium');
            else if (strength <= 4) strengthDiv.classList.add('strong');
            else strengthDiv.classList.add('very-strong');
        });

        // Enhanced form validation and submission
        document.getElementById('providerRegisterForm').addEventListener('submit', function (e) {
            e.preventDefault();

            // Validate form
            const validationResult = validateForm();
            if (!validationResult.isValid) {
                showFormErrors(validationResult.errors);
                return;
            }

            // Show loading state
            const btn = document.getElementById('registerBtn');
            const btnText = btn.querySelector('.btn-text');
            const btnLoading = btn.querySelector('.btn-loading');

            btnText.classList.add('d-none');
            btnLoading.classList.remove('d-none');
            btn.disabled = true;

            // Submit form
            this.submit();
        });

        function validateForm() {
            const errors = [];

            // Check required fields
            const requiredFields = [
                'firstName', 'lastName', 'email', 'phone', 'password', 'confirmPassword',
                'professionalTitle', 'specialization', 'yearsOfExperience', 'licenseNumber'
            ];

            requiredFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (!field.value.trim()) {
                    errors.push(`${getFieldLabel(fieldId)} is required`);
                }
            });

            // Validate email format
            const email = document.getElementById('email').value;
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (email && !emailRegex.test(email)) {
                errors.push('Please enter a valid email address');
            }

            // Validate phone format
            const phone = document.getElementById('phone').value;
            const phoneRegex = /^[\+]?[1-9][\d]{0,15}$/;
            if (phone && !phoneRegex.test(phone.replace(/[\s\-\(\)]/g, ''))) {
                errors.push('Please enter a valid phone number');
            }

            // Validate password match
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            if (password !== confirmPassword) {
                errors.push('Passwords do not match');
            }

            // Validate password strength
            if (password && password.length < 8) {
                errors.push('Password must be at least 8 characters long');
            }

            // Validate years of experience
            const yearsOfExperience = parseInt(document.getElementById('yearsOfExperience').value);
            if (yearsOfExperience < 0 || yearsOfExperience > 50) {
                errors.push('Years of experience must be between 0 and 50');
            }

            // Check if at least one service is selected
            if (!serviceSelector || serviceSelector.selectedServices.size === 0) {
                errors.push('Please select at least one service category');
            }

            // Check if license document is uploaded
            const licenseDocument = document.getElementById('licenseDocument');
            if (!licenseDocument.files || licenseDocument.files.length === 0) {
                errors.push('Professional license document is required');
            }

            // Check terms acceptance
            const terms = document.getElementById('terms');
            if (!terms.checked) {
                errors.push('You must accept the terms and conditions');
            }

            return {
                isValid: errors.length === 0,
                errors: errors
            };
        }

        function getFieldLabel(fieldId) {
            const labels = {
                'firstName': 'First Name',
                'lastName': 'Last Name',
                'email': 'Email Address',
                'phone': 'Phone Number',
                'password': 'Password',
                'confirmPassword': 'Confirm Password',
                'professionalTitle': 'Professional Title',
                'specialization': 'Specialization',
                'yearsOfExperience': 'Years of Experience',
                'licenseNumber': 'License Number'
            };
            return labels[fieldId] || fieldId;
        }

        function showFormErrors(errors) {
            // Remove existing error messages
            document.querySelectorAll('.form-error').forEach(error => error.remove());

            // Show error alert
            const errorAlert = document.createElement('div');
            errorAlert.className = 'alert alert-danger mb-4';
            errorAlert.innerHTML = `
                <h6 class="alert-heading">
                    <i class="fas fa-exclamation-triangle me-2"></i>Please fix the following errors:
                </h6>
                <ul class="mb-0">
                    ${errors.map(error => `<li>${error}</li>`).join('')}
                </ul>
            `;

            // Insert error alert at the top of the form
            const form = document.getElementById('providerRegisterForm');
            form.insertBefore(errorAlert, form.firstChild);

            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });

            // Reset button state
            const btn = document.getElementById('registerBtn');
            const btnText = btn.querySelector('.btn-text');
            const btnLoading = btn.querySelector('.btn-loading');

            btnText.classList.remove('d-none');
            btnLoading.classList.add('d-none');
            btn.disabled = false;
        }

        // File input styling and validation
        function setupFileInput(inputId, labelSelector, maxFiles = 1, maxSize = 5) {
            const input = document.getElementById(inputId);
            const label = document.querySelector(labelSelector);

            input.addEventListener('change', function () {
                const files = Array.from(this.files);
                const validFiles = [];
                const errors = [];

                // Validate files
                files.forEach((file, index) => {
                    // Check file size (5MB limit)
                    if (file.size > maxSize * 1024 * 1024) {
                        errors.push(`${file.name}: File size exceeds ${maxSize}MB limit`);
                        return;
                    }

                    // Check file type
                    const allowedTypes = ['application/pdf', 'image/jpeg', 'image/jpg', 'image/png'];
                    if (!allowedTypes.includes(file.type)) {
                        errors.push(`${file.name}: Invalid file type. Only PDF, JPG, JPEG, PNG are allowed`);
                        return;
                    }

                    validFiles.push(file);
                });

                // Check file count limit
                if (validFiles.length > maxFiles) {
                    errors.push(`Maximum ${maxFiles} file(s) allowed`);
                }

                // Show errors if any
                if (errors.length > 0) {
                    alert('File Upload Errors:\n' + errors.join('\n'));
                    this.value = ''; // Clear the input
                    return;
                }

                // Update UI
                if (validFiles.length > 0) {
                    const icon = validFiles.length === 1 ? 'fa-check' : 'fa-check-double';
                    label.innerHTML = `<i class="fas ${icon} me-2"></i>${validFiles.length} file(s) selected`;
                    label.classList.remove('btn-primary', 'btn-secondary');
                    label.classList.add('btn-success');

                    // Show file preview
                    showFilePreview(validFiles, inputId);
                } else {
                    const originalText = inputId === 'licenseDocument' ? 'Choose License' : 'Add Certificates';
                    const originalIcon = inputId === 'licenseDocument' ? 'fa-upload' : 'fa-plus';
                    label.innerHTML = `<i class="fas ${originalIcon} me-2"></i>${originalText}`;
                    label.classList.remove('btn-success');
                    label.classList.add(inputId === 'licenseDocument' ? 'btn-primary' : 'btn-secondary');

                    // Hide file preview
                    hideFilePreview(inputId);
                }
            });
        }

        // Setup file inputs
        setupFileInput('licenseDocument', 'label[for="licenseDocument"]', 1, 5);
        setupFileInput('additionalDocuments', 'label[for="additionalDocuments"]', 5, 5);

        function showFilePreview(files, inputId) {
            const previewDiv = document.getElementById('filePreview');
            const fileListDiv = document.getElementById('fileList');

            // Clear existing previews for this input
            const existingPreviews = fileListDiv.querySelectorAll(`[data-input="${inputId}"]`);
            existingPreviews.forEach(preview => preview.remove());

            files.forEach((file, index) => {
                const filePreview = document.createElement('div');
                filePreview.className = 'col-md-6 col-lg-4';
                filePreview.dataset.input = inputId;

                const fileIcon = file.type === 'application/pdf' ? 'fa-file-pdf' : 'fa-file-image';
                const fileSize = (file.size / 1024 / 1024).toFixed(2);

                filePreview.innerHTML = `
                    <div class="bg-white border border-gray-200 rounded-lg p-3 d-flex align-items-center">
                        <div class="me-3">
                            <i class="fas ${fileIcon} text-primary fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold text-dark text-truncate" style="max-width: 150px;" title="${file.name}">
                                ${file.name}
                            </div>
                            <small class="text-gray-500">${fileSize} MB</small>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger ms-2" onclick="removeFile('${inputId}', ${index})">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                `;

                fileListDiv.appendChild(filePreview);
            });

            previewDiv.style.display = 'block';
        }

        function hideFilePreview(inputId) {
            const fileListDiv = document.getElementById('fileList');
            const existingPreviews = fileListDiv.querySelectorAll(`[data-input="${inputId}"]`);
            existingPreviews.forEach(preview => preview.remove());

            // Hide preview if no files are selected
            if (fileListDiv.children.length === 0) {
                document.getElementById('filePreview').style.display = 'none';
            }
        }

        function removeFile(inputId, fileIndex) {
            const input = document.getElementById(inputId);
            const files = Array.from(input.files);
            files.splice(fileIndex, 1);

            // Create new FileList (this is a workaround since FileList is read-only)
            const dt = new DataTransfer();
            files.forEach(file => dt.items.add(file));
            input.files = dt.files;

            // Trigger change event to update UI
            input.dispatchEvent(new Event('change'));
        }

        // Service Selection Functionality
        class ServiceSelector {
            constructor() {
                this.selectedServices = new Set();
                this.categories = [];
                this.init();
            }

            async init() {
                await this.loadServiceCategories();
                this.setupEventListeners();
            }

            async loadServiceCategories() {
                try {
                    const response = await fetch('/api/services/categories');
                    const data = await response.json();

                    if (data.success && data.data) {
                        this.categories = data.data;
                        this.renderCategories();
                    } else {
                        this.showError('Failed to load service categories');
                    }
                } catch (error) {
                    console.error('Error loading service categories:', error);
                    this.showError('Failed to load service categories. Please refresh the page to try again.');
                }
            }

            renderCategories() {
                const loadingDiv = document.getElementById('categoriesLoading');
                const containerDiv = document.getElementById('categoriesContainer');
                const gridDiv = document.getElementById('categoriesGrid');

                // Hide loading and show container
                loadingDiv.style.display = 'none';
                containerDiv.style.display = 'block';

                // Clear existing content
                gridDiv.innerHTML = '';

                // Render each category
                this.categories.forEach(category => {
                    const categoryCard = this.createCategoryCard(category);
                    gridDiv.appendChild(categoryCard);
                });
            }

            createCategoryCard(category) {
                const colDiv = document.createElement('div');
                colDiv.className = 'col-md-4 col-sm-6';

                const cardDiv = document.createElement('div');
                cardDiv.className = 'bg-white border-2 border-gray-200 rounded-2xl p-4 cursor-pointer transition hover:border-primary hover:shadow-md position-relative';
                cardDiv.dataset.categoryId = category._id;
                cardDiv.dataset.categoryName = category.name;

                // Use category color if available, otherwise use default
                const cardColor = category.color || '#667eea';
                const iconClass = category.icon ? (category.icon.startsWith('fa-') ? `fas ${category.icon}` : `fas fa-${category.icon}`) : 'fas fa-user-md';

                cardDiv.innerHTML = `
                    <div class="w-14 h-14 rounded-xl flex items-center justify-center text-white text-xl mx-auto mb-3" style="background: ${cardColor};">
                        <i class="${iconClass}"></i>
                    </div>
                    <div class="text-lg font-semibold text-dark text-center mb-2">${category.name}</div>
                    <div class="text-gray-600 text-center text-sm">${category.shortDescription || category.description || ''}</div>
                    ${category.requirements && category.requirements.length > 0 ? `
                        <div class="mt-3">
                            <small class="text-primary fw-semibold">Requirements:</small>
                            <ul class="list-unstyled mt-1">
                                ${category.requirements.slice(0, 2).map(req => `<li class="text-xs text-gray-500">• ${req}</li>`).join('')}
                                ${category.requirements.length > 2 ? `<li class="text-xs text-gray-500">• +${category.requirements.length - 2} more</li>` : ''}
                            </ul>
                        </div>
                    ` : ''}
                `;

                cardDiv.addEventListener('click', () => this.toggleCategory(category));

                colDiv.appendChild(cardDiv);
                return colDiv;
            }

            toggleCategory(category) {
                const categoryId = category._id;
                const categoryCard = document.querySelector(`[data-category-id="${categoryId}"]`);

                if (this.selectedServices.has(categoryId)) {
                    // Remove service
                    this.selectedServices.delete(categoryId);
                    categoryCard.classList.remove('selected', 'border-success');
                } else {
                    // Add service
                    this.selectedServices.add(categoryId);
                    categoryCard.classList.add('selected', 'border-success');
                }

                this.updateSelectedServicesDisplay();
                this.updateFormData();
            }

            updateSelectedServicesDisplay() {
                const summaryDiv = document.getElementById('selectedServicesSummary');
                const listDiv = document.getElementById('selectedServicesList');

                if (this.selectedServices.size === 0) {
                    summaryDiv.style.display = 'none';
                    return;
                }

                summaryDiv.style.display = 'block';
                listDiv.innerHTML = '';

                this.selectedServices.forEach(categoryId => {
                    const category = this.categories.find(cat => cat._id === categoryId);
                    if (category) {
                        const serviceTag = this.createServiceTag(category);
                        listDiv.appendChild(serviceTag);
                    }
                });
            }

            createServiceTag(category) {
                const tagDiv = document.createElement('div');
                tagDiv.className = 'bg-gradient-to-br from-green-500 to-teal-500 text-white px-3 py-2 rounded-full text-sm font-medium d-flex align-items-center gap-2';

                tagDiv.innerHTML = `
                    <span>${category.name}</span>
                    <button type="button" class="remove-service" onclick="serviceSelector.removeService('${category._id}')">
                        <i class="fas fa-times"></i>
                    </button>
                `;

                return tagDiv;
            }

            removeService(categoryId) {
                const categoryCard = document.querySelector(`[data-category-id="${categoryId}"]`);
                if (categoryCard) {
                    categoryCard.classList.remove('selected', 'border-success');
                }
                this.selectedServices.delete(categoryId);
                this.updateSelectedServicesDisplay();
                this.updateFormData();
            }

            updateFormData() {
                // Remove existing hidden inputs
                const existingInputs = document.querySelectorAll('input[name="selectedServices[]"]');
                existingInputs.forEach(input => input.remove());

                // Add new hidden inputs for selected services
                const form = document.getElementById('providerRegisterForm');
                this.selectedServices.forEach(categoryId => {
                    const hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'selectedServices[]';
                    hiddenInput.value = categoryId;
                    form.appendChild(hiddenInput);
                });

                // Update services count
                const countInput = document.getElementById('selectedServicesCount');
                const countBadge = document.getElementById('servicesCount');

                if (countInput) {
                    countInput.value = this.selectedServices.size;
                }

                if (countBadge) {
                    if (this.selectedServices.size > 0) {
                        countBadge.textContent = this.selectedServices.size;
                        countBadge.style.display = 'inline-block';
                    } else {
                        countBadge.style.display = 'none';
                    }
                }
            }

            showError(message) {
                const loadingDiv = document.getElementById('categoriesLoading');
                loadingDiv.innerHTML = `
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <div>${message}</div>
                        <button type="button" class="btn btn-sm btn-outline-danger ms-3" onclick="serviceSelector.loadServiceCategories()">
                            <i class="fas fa-redo me-1"></i>Retry
                        </button>
                    </div>
                `;
            }

            setupEventListeners() {
                // Form validation to ensure at least one service is selected
                const form = document.getElementById('providerRegisterForm');
                form.addEventListener('submit', (e) => {
                    if (this.selectedServices.size === 0) {
                        e.preventDefault();

                        // Show better error message
                        const serviceSection = document.querySelector('.service-selection-container');
                        serviceSection.style.border = '2px solid #dc3545';
                        serviceSection.style.background = '#f8d7da';

                        // Add error message
                        let errorMsg = serviceSection.querySelector('.service-error-msg');
                        if (!errorMsg) {
                            errorMsg = document.createElement('div');
                            errorMsg.className = 'alert alert-danger service-error-msg mt-3';
                            errorMsg.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>Please select at least one service category that you want to offer.';
                            serviceSection.appendChild(errorMsg);
                        }

                        // Scroll to service section
                        document.getElementById('categoriesContainer').scrollIntoView({ behavior: 'smooth' });

                        // Reset button state
                        const btn = document.getElementById('registerBtn');
                        const btnText = btn.querySelector('.btn-text');
                        const btnLoading = btn.querySelector('.btn-loading');

                        btnText.classList.remove('d-none');
                        btnLoading.classList.add('d-none');
                        btn.disabled = false;

                        return false;
                    } else {
                        // Remove error styling if services are selected
                        const serviceSection = document.querySelector('.service-selection-container');
                        serviceSection.style.border = '';
                        serviceSection.style.background = '';

                        const errorMsg = serviceSection.querySelector('.service-error-msg');
                        if (errorMsg) {
                            errorMsg.remove();
                        }
                    }
                });
            }
        }

        // Real-time form validation
        function setupRealTimeValidation() {
            // Email validation
            document.getElementById('email').addEventListener('blur', function () {
                const email = this.value;
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                const feedback = this.parentElement.querySelector('.invalid-feedback') || createFeedbackElement(this);

                if (email && !emailRegex.test(email)) {
                    this.classList.add('is-invalid');
                    feedback.textContent = 'Please enter a valid email address';
                    feedback.style.display = 'block';
                } else {
                    this.classList.remove('is-invalid');
                    feedback.style.display = 'none';
                }
            });

            // Phone validation
            document.getElementById('phone').addEventListener('blur', function () {
                const phone = this.value;
                const phoneRegex = /^[\+]?[1-9][\d]{0,15}$/;
                const feedback = this.parentElement.querySelector('.invalid-feedback') || createFeedbackElement(this);

                if (phone && !phoneRegex.test(phone.replace(/[\s\-\(\)]/g, ''))) {
                    this.classList.add('is-invalid');
                    feedback.textContent = 'Please enter a valid phone number';
                    feedback.style.display = 'block';
                } else {
                    this.classList.remove('is-invalid');
                    feedback.style.display = 'none';
                }
            });

            // Password confirmation validation
            document.getElementById('confirmPassword').addEventListener('input', function () {
                const password = document.getElementById('password').value;
                const confirmPassword = this.value;
                const feedback = this.parentElement.querySelector('.invalid-feedback') || createFeedbackElement(this);

                if (confirmPassword && password !== confirmPassword) {
                    this.classList.add('is-invalid');
                    feedback.textContent = 'Passwords do not match';
                    feedback.style.display = 'block';
                } else {
                    this.classList.remove('is-invalid');
                    feedback.style.display = 'none';
                }
            });

            // Years of experience validation
            document.getElementById('yearsOfExperience').addEventListener('blur', function () {
                const value = parseInt(this.value);
                const feedback = this.parentElement.querySelector('.invalid-feedback') || createFeedbackElement(this);

                if (this.value && (value < 0 || value > 50)) {
                    this.classList.add('is-invalid');
                    feedback.textContent = 'Years of experience must be between 0 and 50';
                    feedback.style.display = 'block';
                } else {
                    this.classList.remove('is-invalid');
                    feedback.style.display = 'none';
                }
            });
        }

        function createFeedbackElement(input) {
            const feedback = document.createElement('div');
            feedback.className = 'invalid-feedback';
            feedback.style.display = 'none';
            input.parentElement.appendChild(feedback);
            return feedback;
        }

        // Add progress indicator
        function updateProgressIndicator() {
            const sections = document.querySelectorAll('.mb-8.pb-6.border-b.border-gray-200');
            const progressBar = document.createElement('div');
            progressBar.className = 'progress mb-4';
            progressBar.style.height = '8px';
            progressBar.innerHTML = `
                <div class="progress-bar bg-gradient-to-r from-primary to-secondary" role="progressbar" style="width: 0%" id="formProgress"></div>
            `;

            const form = document.getElementById('providerRegisterForm');
            form.insertBefore(progressBar, form.firstChild);

            // Update progress on scroll
            window.addEventListener('scroll', function () {
                const scrollTop = window.pageYOffset;
                const docHeight = document.body.scrollHeight - window.innerHeight;
                const scrollPercent = (scrollTop / docHeight) * 100;
                document.getElementById('formProgress').style.width = Math.min(scrollPercent, 100) + '%';
            });
        }

        // Location form functionality
        function setupLocationForm() {
            // Insurance acceptance toggle
            const acceptsInsuranceCheckbox = document.getElementById('acceptsInsurance');
            const insuranceProvidersDiv = document.getElementById('insuranceProviders');

            acceptsInsuranceCheckbox.addEventListener('change', function () {
                if (this.checked) {
                    insuranceProvidersDiv.style.display = 'block';
                } else {
                    insuranceProvidersDiv.style.display = 'none';
                    // Uncheck all insurance provider checkboxes
                    insuranceProvidersDiv.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                        checkbox.checked = false;
                    });
                }
            });

            // Practice type change handler
            const practiceTypeSelect = document.getElementById('practiceType');
            const addressFields = document.querySelectorAll('#address, #city, #state, #zipCode');

            practiceTypeSelect.addEventListener('change', function () {
                if (this.value === 'telemedicine_only') {
                    // Make address fields optional for telemedicine-only
                    addressFields.forEach(field => {
                        field.required = false;
                        field.parentElement.querySelector('.form-text').innerHTML =
                            '<i class="fas fa-info-circle me-1"></i>Optional for telemedicine-only practices';
                    });
                } else {
                    // Make address fields required for physical practices
                    addressFields.forEach(field => {
                        field.required = true;
                        field.parentElement.querySelector('.form-text').innerHTML =
                            '<i class="fas fa-map-pin me-1"></i>Required for physical practice locations';
                    });
                }
            });

            // ZIP code validation
            const zipCodeInput = document.getElementById('zipCode');
            zipCodeInput.addEventListener('input', function () {
                const zipRegex = /^\d{5}(-\d{4})?$/;
                const feedback = this.parentElement.querySelector('.invalid-feedback') || createFeedbackElement(this);

                if (this.value && !zipRegex.test(this.value)) {
                    this.classList.add('is-invalid');
                    feedback.textContent = 'Please enter a valid ZIP code (12345 or 12345-6789)';
                    feedback.style.display = 'block';
                } else {
                    this.classList.remove('is-invalid');
                    feedback.style.display = 'none';
                }
            });
        }

        // Enhanced form validation to include location fields
        function validateLocationFields() {
            const errors = [];
            const practiceType = document.getElementById('practiceType').value;

            // Only require location for non-telemedicine practices
            if (practiceType !== 'telemedicine_only') {
                const requiredLocationFields = ['address', 'city', 'state', 'zipCode'];

                requiredLocationFields.forEach(fieldId => {
                    const field = document.getElementById(fieldId);
                    if (!field.value.trim()) {
                        errors.push(`${getFieldLabel(fieldId)} is required for physical practice locations`);
                    }
                });

                // Validate ZIP code format
                const zipCode = document.getElementById('zipCode').value;
                const zipRegex = /^\d{5}(-\d{4})?$/;
                if (zipCode && !zipRegex.test(zipCode)) {
                    errors.push('Please enter a valid ZIP code');
                }
            }

            return errors;
        }

        // Update the main validation function
        function validateForm() {
            const errors = [];

            // Check required fields
            const requiredFields = [
                'firstName', 'lastName', 'email', 'phone', 'password', 'confirmPassword',
                'professionalTitle', 'specialization', 'yearsOfExperience', 'licenseNumber'
            ];

            requiredFields.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                if (!field.value.trim()) {
                    errors.push(`${getFieldLabel(fieldId)} is required`);
                }
            });

            // Validate email format
            const email = document.getElementById('email').value;
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (email && !emailRegex.test(email)) {
                errors.push('Please enter a valid email address');
            }

            // Validate phone format
            const phone = document.getElementById('phone').value;
            const phoneRegex = /^[\+]?[1-9][\d]{0,15}$/;
            if (phone && !phoneRegex.test(phone.replace(/[\s\-\(\)]/g, ''))) {
                errors.push('Please enter a valid phone number');
            }

            // Validate password match
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            if (password !== confirmPassword) {
                errors.push('Passwords do not match');
            }

            // Validate password strength
            if (password && password.length < 8) {
                errors.push('Password must be at least 8 characters long');
            }

            // Validate years of experience
            const yearsOfExperience = parseInt(document.getElementById('yearsOfExperience').value);
            if (yearsOfExperience < 0 || yearsOfExperience > 50) {
                errors.push('Years of experience must be between 0 and 50');
            }

            // Check if at least one service is selected
            if (!serviceSelector || serviceSelector.selectedServices.size === 0) {
                errors.push('Please select at least one service category');
            }

            // Check if license document is uploaded
            const licenseDocument = document.getElementById('licenseDocument');
            if (!licenseDocument.files || licenseDocument.files.length === 0) {
                errors.push('Professional license document is required');
            }

            // Check terms acceptance
            const terms = document.getElementById('terms');
            if (!terms.checked) {
                errors.push('You must accept the terms and conditions');
            }

            // Validate location fields
            const locationErrors = validateLocationFields();
            errors.push(...locationErrors);

            return {
                isValid: errors.length === 0,
                errors: errors
            };
        }

        // Initialize everything when page loads
        let serviceSelector;
        document.addEventListener('DOMContentLoaded', function () {
            serviceSelector = new ServiceSelector();
            setupRealTimeValidation();
            setupLocationForm();
            updateProgressIndicator();

            // Add smooth scrolling to form sections
            document.querySelectorAll('h3').forEach(heading => {
                heading.style.cursor = 'pointer';
                heading.addEventListener('click', function () {
                    this.scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });
        });
    </script>
</body>

</html>