<!-- Page Heading -->
<div class="d-sm-flex align-items-center justify-content-between mt-5">
    <h1 class="h3 mb-0 text-gray-800">Service Management</h1>
    <button type="button" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm" data-toggle="modal"
        data-target="#addServiceModal">
        <i class="fas fa-plus fa-sm text-white-50"></i> Add New Service
    </button>
</div>

<!-- Statistics Row -->
<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Services</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="totalServices">0</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-stethoscope fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Active Services</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="activeServices">0</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Pending Approval</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="pendingServices">0</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-clock fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Monthly Revenue</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="monthlyRevenue">$0</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Services Table -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">My Services</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <!-- CSV Upload area -->
            <div class="mb-3">
                <form id="uploadCsvForm" enctype="multipart/form-data">
                    <div class="form-row align-items-center">
                        <div class="col-auto">
                            <input type="file" class="form-control-file" id="csvFileInput" name="csvFile" accept=".csv">
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-outline-primary btn-sm">Upload CSV</button>
                        </div>
                        <div class="col-auto">
                            <a href="/public/assets/sample-services.csv" class="btn btn-link btn-sm">Download sample
                                CSV</a>
                        </div>
                    </div>
                </form>
                <small class="form-text text-muted">Upload a CSV with columns:
                    name,category,duration,price,currency,description,shortDescription,isVirtual</small>
            </div>
            <table class="table table-bordered" id="servicesTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Service Name</th>
                        <th>Category</th>
                        <th>Duration</th>
                        <th>Price</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="servicesTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Service Modal -->
<div class="modal fade" id="addServiceModal" tabindex="-1" role="dialog" aria-labelledby="addServiceModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="addServiceModalLabel"><i
                        class="fas fa-plus-circle text-primary mr-2"></i>Add New Service</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span
                        aria-hidden="true">&times;</span></button>
            </div>
            <form id="addServiceForm" novalidate>
                <div class="modal-body pt-3">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="serviceName" class="mb-1">Service Name <span
                                        class="text-danger">*</span></label>
                                <div class="input-group">
                                    <div class="input-group-prepend"><span class="input-group-text"><i
                                                class="fas fa-file-signature"></i></span></div>
                                    <input type="text" class="form-control" id="serviceName" name="name"
                                        placeholder="e.g. General Consultation" minlength="3" maxlength="80" required>
                                </div>
                                <small class="text-muted">Clear, concise name patients will see.</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="serviceCategory" class="mb-1">Service Category <span
                                        class="text-danger">*</span></label>
                                <div class="input-group">
                                    <div class="input-group-prepend"><span class="input-group-text"><i
                                                class="fas fa-layer-group"></i></span></div>
                                    <select class="form-control" id="serviceCategory" name="category" required>
                                        <option value="">Select Category</option>
                                    </select>
                                </div>
                                <small class="text-muted">Choose the most relevant specialty.</small>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="serviceDuration" class="mb-1">Duration (minutes) <span
                                        class="text-danger">*</span></label>
                                <div class="input-group">
                                    <div class="input-group-prepend"><span class="input-group-text"><i
                                                class="far fa-clock"></i></span></div>
                                    <input type="number" class="form-control" id="serviceDuration" name="duration"
                                        min="15" step="15" placeholder="30" required>
                                </div>
                                <small class="text-muted">Typical duration of this service.</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="servicePrice" class="mb-1">Price</label>
                                <div class="input-group">
                                    <div class="input-group-prepend"><span class="input-group-text"><i
                                                class="fas fa-rupee-sign"></i></span></div>
                                    <input type="number" class="form-control" id="servicePrice" name="price" min="0"
                                        step="0.01" placeholder="0.00">
                                </div>
                                <small class="text-muted">Service price (optional).</small>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="serviceCurrency" class="mb-1">Currency</label>
                                <div class="input-group">
                                    <div class="input-group-prepend"><span class="input-group-text"><i
                                                class="fas fa-dollar-sign"></i></span></div>
                                    <select class="form-control" id="serviceCurrency" name="currency">
                                        <option value="INR">INR (₹)</option>
                                        <option value="USD">USD ($)</option>
                                        <option value="EUR">EUR (€)</option>
                                        <option value="GBP">GBP (£)</option>
                                    </select>
                                </div>
                                <small class="text-muted">Currency for pricing.</small>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="serviceDescription" class="mb-1">Description</label>
                        <div class="input-group">
                            <div class="input-group-prepend"><span class="input-group-text"><i
                                        class="fas fa-align-left"></i></span></div>
                            <textarea class="form-control" id="serviceDescription" name="description" rows="3"
                                placeholder="Outline what this service includes, preparation steps, and what patients can expect."></textarea>
                        </div>
                    </div>

                    <div class="form-group mb-2">
                        <label for="serviceShortDescription" class="mb-1">Short Description</label>
                        <div class="input-group">
                            <div class="input-group-prepend"><span class="input-group-text"><i
                                        class="fas fa-sticky-note"></i></span></div>
                            <textarea class="form-control" id="serviceShortDescription" name="shortDescription" rows="2"
                                maxlength="200"
                                placeholder="A brief summary shown in listings (max 200 characters)"></textarea>
                        </div>
                        <div class="d-flex justify-content-between"><small class="text-muted">Shown in cards and
                                search.</small><small class="text-muted"><span
                                    id="shortDescCounter">0</span>/200</small></div>
                    </div>

                    <div class="form-group mb-0">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" class="custom-control-input" id="serviceIsVirtual" name="isVirtual">
                            <label class="custom-control-label" for="serviceIsVirtual">Virtual/Online Service</label>
                        </div>
                        <small class="text-muted">Enable if the appointment is conducted online.</small>
                    </div>

                    <!-- Location Section -->
                    <div class="mt-4" id="locationSection">
                        <h6 class="text-primary mb-3"><i class="fas fa-map-marker-alt mr-2"></i>Service Location</h6>
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle mr-2"></i>
                            <strong>Location Required:</strong> For in-person services, please provide the complete
                            address where patients will visit you.
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="serviceAddress" class="mb-1">Address</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend"><span class="input-group-text"><i
                                                    class="fas fa-home"></i></span></div>
                                        <input type="text" class="form-control" id="serviceAddress"
                                            name="location[address]" placeholder="e.g. 123 MG Road, Koramangala">
                                    </div>
                                    <small class="text-muted">Street address for in-person services.</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="serviceCity" class="mb-1">City</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend"><span class="input-group-text"><i
                                                    class="fas fa-city"></i></span></div>
                                        <select class="form-control" id="serviceCity" name="location[city]">
                                            <option value="">Select City</option>
                                            <option value="Bangalore">Bangalore</option>
                                            <option value="Mumbai">Mumbai</option>
                                            <option value="Delhi">Delhi</option>
                                            <option value="Chennai">Chennai</option>
                                            <option value="Hyderabad">Hyderabad</option>
                                            <option value="Pune">Pune</option>
                                            <option value="Kolkata">Kolkata</option>
                                            <option value="Ahmedabad">Ahmedabad</option>
                                            <option value="Jaipur">Jaipur</option>
                                            <option value="Kochi">Kochi</option>
                                            <option value="Other">Other (Please specify)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="serviceState" class="mb-1">State</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend"><span class="input-group-text"><i
                                                    class="fas fa-map"></i></span></div>
                                        <select class="form-control" id="serviceState" name="location[state]">
                                            <option value="">Select State</option>
                                            <option value="Karnataka">Karnataka</option>
                                            <option value="Maharashtra">Maharashtra</option>
                                            <option value="Delhi">Delhi</option>
                                            <option value="Tamil Nadu">Tamil Nadu</option>
                                            <option value="Telangana">Telangana</option>
                                            <option value="West Bengal">West Bengal</option>
                                            <option value="Gujarat">Gujarat</option>
                                            <option value="Rajasthan">Rajasthan</option>
                                            <option value="Kerala">Kerala</option>
                                            <option value="Uttar Pradesh">Uttar Pradesh</option>
                                            <option value="Other">Other (Please specify)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="serviceZipCode" class="mb-1">Pincode</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend"><span class="input-group-text"><i
                                                    class="fas fa-mail-bulk"></i></span></div>
                                        <input type="text" class="form-control" id="serviceZipCode"
                                            name="location[zipCode]" placeholder="e.g. 560034" pattern="[0-9]{6}"
                                            maxlength="6">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="serviceLatitude" class="mb-1">Latitude</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend"><span class="input-group-text"><i
                                                    class="fas fa-crosshairs"></i></span></div>
                                        <input type="number" class="form-control" id="serviceLatitude"
                                            name="location[coordinates][latitude]" step="any"
                                            placeholder="e.g. 12.9716">
                                    </div>
                                    <small class="text-muted">Optional: GPS coordinates for precise location.</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="serviceLongitude" class="mb-1">Longitude</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend"><span class="input-group-text"><i
                                                    class="fas fa-crosshairs"></i></span></div>
                                        <input type="number" class="form-control" id="serviceLongitude"
                                            name="location[coordinates][longitude]" step="any"
                                            placeholder="e.g. 77.5946">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <button type="button" class="btn btn-outline-primary btn-sm" id="getCurrentLocationBtn">
                                    <i class="fas fa-location-arrow mr-2"></i>Get Current Location
                                </button>
                                <small class="text-muted ml-2">Automatically fill coordinates using your device's
                                    GPS</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-dismiss="modal"><i
                            class="fas fa-times mr-1"></i>Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-check mr-1"></i>Create
                        Service</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Service Modal -->
<div class="modal fade" id="editServiceModal" tabindex="-1" role="dialog" aria-labelledby="editServiceModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editServiceModalLabel">Edit Service</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span
                        aria-hidden="true">&times;</span></button>
            </div>
            <form id="editServiceForm">
                <input type="hidden" id="editServiceId" name="serviceId">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editServiceName">Service Name *</label>
                                <input type="text" class="form-control" id="editServiceName" name="name" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editServiceCategory">Service Category *</label>
                                <select class="form-control" id="editServiceCategory" name="category" required>
                                    <option value="">Select Category</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editServiceDuration">Duration (minutes) *</label>
                                <input type="number" class="form-control" id="editServiceDuration" name="duration"
                                    min="15" step="15" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editServicePrice">Price</label>
                                <input type="number" class="form-control" id="editServicePrice" name="price" min="0"
                                    step="0.01" placeholder="0.00">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editServiceCurrency">Currency</label>
                                <select class="form-control" id="editServiceCurrency" name="currency">
                                    <option value="INR">INR (₹)</option>
                                    <option value="USD">USD ($)</option>
                                    <option value="EUR">EUR (€)</option>
                                    <option value="GBP">GBP (£)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="editServiceDescription">Description</label>
                        <textarea class="form-control" id="editServiceDescription" name="description"
                            rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editServiceShortDescription">Short Description</label>
                        <textarea class="form-control" id="editServiceShortDescription" name="shortDescription" rows="2"
                            maxlength="200"></textarea>
                        <small class="form-text text-muted">Maximum 200 characters</small>
                    </div>
                    <div class="form-group">
                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" id="editServiceIsVirtual"
                                name="isVirtual">
                            <label class="custom-control-label" for="editServiceIsVirtual">Virtual/Online
                                Service</label>
                        </div>
                    </div>

                    <!-- Location Section for Edit -->
                    <div class="mt-4" id="editLocationSection">
                        <h6 class="text-primary mb-3"><i class="fas fa-map-marker-alt mr-2"></i>Service Location</h6>
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle mr-2"></i>
                            <strong>Location Required:</strong> For in-person services, please provide the complete
                            address where patients will visit you.
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="editServiceAddress">Address</label>
                                    <input type="text" class="form-control" id="editServiceAddress"
                                        name="location[address]" placeholder="e.g. 123 MG Road, Koramangala">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="editServiceCity">City</label>
                                    <select class="form-control" id="editServiceCity" name="location[city]">
                                        <option value="">Select City</option>
                                        <option value="Bangalore">Bangalore</option>
                                        <option value="Mumbai">Mumbai</option>
                                        <option value="Delhi">Delhi</option>
                                        <option value="Chennai">Chennai</option>
                                        <option value="Hyderabad">Hyderabad</option>
                                        <option value="Pune">Pune</option>
                                        <option value="Kolkata">Kolkata</option>
                                        <option value="Ahmedabad">Ahmedabad</option>
                                        <option value="Jaipur">Jaipur</option>
                                        <option value="Kochi">Kochi</option>
                                        <option value="Other">Other (Please specify)</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="editServiceState">State</label>
                                    <select class="form-control" id="editServiceState" name="location[state]">
                                        <option value="">Select State</option>
                                        <option value="Karnataka">Karnataka</option>
                                        <option value="Maharashtra">Maharashtra</option>
                                        <option value="Delhi">Delhi</option>
                                        <option value="Tamil Nadu">Tamil Nadu</option>
                                        <option value="Telangana">Telangana</option>
                                        <option value="West Bengal">West Bengal</option>
                                        <option value="Gujarat">Gujarat</option>
                                        <option value="Rajasthan">Rajasthan</option>
                                        <option value="Kerala">Kerala</option>
                                        <option value="Uttar Pradesh">Uttar Pradesh</option>
                                        <option value="Other">Other (Please specify)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="editServiceZipCode">Pincode</label>
                                    <input type="text" class="form-control" id="editServiceZipCode"
                                        name="location[zipCode]" placeholder="e.g. 560034" pattern="[0-9]{6}"
                                        maxlength="6">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="editServiceLatitude">Latitude</label>
                                    <input type="number" class="form-control" id="editServiceLatitude"
                                        name="location[coordinates][latitude]" step="any" placeholder="e.g. 12.9716">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="editServiceLongitude">Longitude</label>
                                    <input type="number" class="form-control" id="editServiceLongitude"
                                        name="location[coordinates][longitude]" step="any" placeholder="e.g. 77.5946">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <button type="button" class="btn btn-outline-primary btn-sm"
                                    id="getCurrentLocationEditBtn">
                                    <i class="fas fa-location-arrow mr-2"></i>Get Current Location
                                </button>
                                <small class="text-muted ml-2">Automatically fill coordinates using your device's
                                    GPS</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Service</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        loadServiceCategories();
        loadServices();

        // Handle virtual service toggle for location fields
        const virtualToggle = document.getElementById('serviceIsVirtual');
        const locationSection = document.getElementById('locationSection');

        if (virtualToggle && locationSection) {
            virtualToggle.addEventListener('change', function () {
                if (this.checked) {
                    locationSection.style.opacity = '0.5';
                    locationSection.style.pointerEvents = 'none';
                } else {
                    locationSection.style.opacity = '1';
                    locationSection.style.pointerEvents = 'auto';
                }
            });
        }

        // Handle virtual service toggle for edit modal
        const editVirtualToggle = document.getElementById('editServiceIsVirtual');
        const editLocationSection = document.getElementById('editLocationSection');

        if (editVirtualToggle && editLocationSection) {
            editVirtualToggle.addEventListener('change', function () {
                if (this.checked) {
                    editLocationSection.style.opacity = '0.5';
                    editLocationSection.style.pointerEvents = 'none';
                } else {
                    editLocationSection.style.opacity = '1';
                    editLocationSection.style.pointerEvents = 'auto';
                }
            });
        }

        // Get current location functionality
        const getCurrentLocationBtn = document.getElementById('getCurrentLocationBtn');
        if (getCurrentLocationBtn) {
            getCurrentLocationBtn.addEventListener('click', function () {
                getCurrentLocation('serviceLatitude', 'serviceLongitude');
            });
        }

        const getCurrentLocationEditBtn = document.getElementById('getCurrentLocationEditBtn');
        if (getCurrentLocationEditBtn) {
            getCurrentLocationEditBtn.addEventListener('click', function () {
                getCurrentLocation('editServiceLatitude', 'editServiceLongitude');
            });
        }

        // Auto-open create modal if requested via query ?create=1
        try {
            const params = new URLSearchParams(window.location.search);
            if (params.get('create') === '1') {
                $('#addServiceModal').modal('show');
            }
        } catch (e) { }
    });

    async function loadServiceCategories() {
        try {
            const response = await fetch('/api/services/categories');
            const data = await response.json();
            if (data.success) {
                ['#serviceCategory', '#editServiceCategory'].forEach(selectId => {
                    const select = document.querySelector(selectId);
                    select.innerHTML = '<option value="">Select Category</option>';
                    data.data.forEach(category => {
                        const option = document.createElement('option');
                        option.value = category._id;
                        option.textContent = category.name;
                        select.appendChild(option);
                    });
                });
            }
        } catch (error) {
            console.error('Error loading categories:', error);
        }
    }

    async function loadServices() {
        try {
            const response = await fetch('/api/provider/services');
            const data = await response.json();
            if (data.success) {
                updateStatistics(data.data);
                renderServicesTable(data.data);
            }
        } catch (error) {
            console.error('Error loading services:', error);
        }
    }

    function updateStatistics(services) {
        const total = services.length;
        const active = services.filter(s => s.isActive).length;
        const pending = services.filter(s => s.approvalStatus === 'pending').length;
        document.getElementById('totalServices').textContent = total;
        document.getElementById('activeServices').textContent = active;
        document.getElementById('pendingServices').textContent = pending;
    }

    function renderServicesTable(services) {
        const tbody = document.getElementById('servicesTableBody');
        tbody.innerHTML = '';
        if (services.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center">No services found</td></tr>';
            return;
        }
        services.forEach(service => {
            const row = document.createElement('tr');
            const price = service.price ? `${service.currency || 'INR'} ${service.price}` : 'Not set';
            const location = service.location ?
                (service.isVirtual ? '<span class="badge badge-info">Virtual</span>' :
                    `${service.location.city || 'N/A'}, ${service.location.state || 'N/A'}`) :
                'Not set';

            row.innerHTML = `
            <td>${service.name}</td>
            <td>${service.category ? service.category.name : 'N/A'}</td>
            <td>${service.duration} min</td>
            <td>${price}</td>
            <td>${location}</td>
            <td>
                <span class="badge badge-${getStatusBadgeClass(service.approvalStatus)}">${service.approvalStatus}</span>
            </td>
            <td>
                <button class="btn btn-sm btn-primary" onclick="editService('${service._id}')"><i class="fas fa-edit"></i></button>
                <button class="btn btn-sm btn-${service.isActive ? 'warning' : 'success'}" onclick="toggleServiceStatus('${service._id}', ${service.isActive})"><i class="fas fa-${service.isActive ? 'pause' : 'play'}"></i></button>
                <button class="btn btn-sm btn-danger" onclick="deleteService('${service._id}')"><i class="fas fa-trash"></i></button>
            </td>`;
            tbody.appendChild(row);
        });
    }

    function getStatusBadgeClass(status) {
        switch (status) {
            case 'approved': return 'success';
            case 'pending': return 'warning';
            case 'rejected': return 'danger';
            default: return 'secondary';
        }
    }

    document.getElementById('addServiceForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        try {
            const formData = new FormData(this);
            const serviceData = Object.fromEntries(formData);

            // Convert duration to number
            if (serviceData.duration) {
                serviceData.duration = parseInt(serviceData.duration, 10);
            }

            // Convert isVirtual to boolean
            serviceData.isVirtual = formData.get('isVirtual') === 'on';

            // Build location object
            const location = {};
            if (serviceData['location[address]']) location.address = serviceData['location[address]'];
            if (serviceData['location[city]']) location.city = serviceData['location[city]'];
            if (serviceData['location[state]']) location.state = serviceData['location[state]'];
            if (serviceData['location[zipCode]']) location.zipCode = serviceData['location[zipCode]'];

            if (serviceData['location[coordinates][latitude]'] || serviceData['location[coordinates][longitude]']) {
                location.coordinates = {};
                if (serviceData['location[coordinates][latitude]']) location.coordinates.latitude = parseFloat(serviceData['location[coordinates][latitude]']);
                if (serviceData['location[coordinates][longitude]']) location.coordinates.longitude = parseFloat(serviceData['location[coordinates][longitude]']);
            }

            // Clean up location fields from serviceData
            Object.keys(serviceData).forEach(key => {
                if (key.startsWith('location[')) {
                    delete serviceData[key];
                }
            });

            // Add location to serviceData if it has any properties
            if (Object.keys(location).length > 0) {
                serviceData.location = location;
            }

            console.log('Sending service data:', serviceData);

            const response = await fetch('/api/provider/services', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(serviceData)
            });

            const data = await response.json();
            console.log('Response data:', data);

            if (data.success) {
                $('#addServiceModal').modal('hide');
                this.reset();
                loadServices();
                showAlert('Service created successfully!', 'success');
            } else {
                showAlert(data.message || 'Failed to create service', 'danger');
            }
        } catch (error) {
            console.error('Error creating service:', error);
            showAlert('An error occurred while creating the service', 'danger');
        }
    });

    async function editService(serviceId) {
        try {
            const response = await fetch(`/api/provider/services/${serviceId}`);
            const data = await response.json();
            if (data.success) {
                const service = data.data;
                document.getElementById('editServiceId').value = service._id;
                document.getElementById('editServiceName').value = service.name;
                document.getElementById('editServiceCategory').value = service.category._id;
                document.getElementById('editServiceDuration').value = service.duration;
                document.getElementById('editServicePrice').value = service.price || '';
                document.getElementById('editServiceDescription').value = service.description || '';
                document.getElementById('editServiceShortDescription').value = service.shortDescription || '';
                document.getElementById('editServiceCurrency').value = service.currency;
                document.getElementById('editServiceIsVirtual').checked = service.isVirtual;

                // Populate location fields
                if (service.location) {
                    document.getElementById('editServiceAddress').value = service.location.address || '';
                    document.getElementById('editServiceCity').value = service.location.city || '';
                    document.getElementById('editServiceState').value = service.location.state || '';
                    document.getElementById('editServiceZipCode').value = service.location.zipCode || '';
                    if (service.location.coordinates) {
                        document.getElementById('editServiceLatitude').value = service.location.coordinates.latitude || '';
                        document.getElementById('editServiceLongitude').value = service.location.coordinates.longitude || '';
                    }
                }

                $('#editServiceModal').modal('show');
            }
        } catch (error) {
            console.error('Error loading service for edit:', error);
        }
    }

    document.getElementById('editServiceForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        try {
            const formData = new FormData(this);
            const serviceData = Object.fromEntries(formData);
            const serviceId = serviceData.serviceId;
            delete serviceData.serviceId;
            serviceData.isVirtual = formData.get('isVirtual') === 'on';

            // Build location object for edit
            const location = {};
            if (serviceData['location[address]']) location.address = serviceData['location[address]'];
            if (serviceData['location[city]']) location.city = serviceData['location[city]'];
            if (serviceData['location[state]']) location.state = serviceData['location[state]'];
            if (serviceData['location[zipCode]']) location.zipCode = serviceData['location[zipCode]'];

            if (serviceData['location[coordinates][latitude]'] || serviceData['location[coordinates][longitude]']) {
                location.coordinates = {};
                if (serviceData['location[coordinates][latitude]']) location.coordinates.latitude = parseFloat(serviceData['location[coordinates][latitude]']);
                if (serviceData['location[coordinates][longitude]']) location.coordinates.longitude = parseFloat(serviceData['location[coordinates][longitude]']);
            }

            // Clean up location fields from serviceData
            Object.keys(serviceData).forEach(key => {
                if (key.startsWith('location[')) {
                    delete serviceData[key];
                }
            });

            // Add location to serviceData if it has any properties
            if (Object.keys(location).length > 0) {
                serviceData.location = location;
            }
            const response = await fetch(`/api/provider/services/${serviceId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(serviceData) });
            const data = await response.json();
            if (data.success) { $('#editServiceModal').modal('hide'); this.reset(); loadServices(); showAlert('Service updated successfully!', 'success'); }
            else { showAlert(data.message || 'Failed to update service', 'danger'); }
        } catch (error) {
            console.error('Error updating service:', error);
            showAlert('An error occurred while updating the service', 'danger');
        }
    });

    async function toggleServiceStatus(serviceId, currentStatus) {
        try {
            const response = await fetch(`/api/provider/services/${serviceId}/toggle-status`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ isActive: !currentStatus }) });
            const data = await response.json();
            if (data.success) { loadServices(); showAlert('Service status updated successfully!', 'success'); }
            else { showAlert(data.message || 'Failed to update service status', 'danger'); }
        } catch (error) {
            console.error('Error toggling service status:', error);
            showAlert('An error occurred while updating the service status', 'danger');
        }
    }

    async function deleteService(serviceId) {
        if (!confirm('Are you sure you want to delete this service? This action cannot be undone.')) return;
        try {
            const response = await fetch(`/api/provider/services/${serviceId}`, { method: 'DELETE' });
            const data = await response.json();
            if (data.success) { loadServices(); showAlert('Service deleted successfully!', 'success'); }
            else { showAlert(data.message || 'Failed to delete service', 'danger'); }
        } catch (error) {
            console.error('Error deleting service:', error);
            showAlert('An error occurred while deleting the service', 'danger');
        }
    }

    function showAlert(message, type) {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
        alertDiv.innerHTML = `${message}<button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>`;
        const container = document.querySelector('.container-fluid');
        container.insertBefore(alertDiv, container.firstChild);
        setTimeout(() => { alertDiv.remove(); }, 5000);
    }

    function getCurrentLocation(latFieldId, lngFieldId) {
        if (!navigator.geolocation) {
            showAlert('Geolocation is not supported by this browser.', 'warning');
            return;
        }

        const latField = document.getElementById(latFieldId);
        const lngField = document.getElementById(lngFieldId);

        if (!latField || !lngField) {
            showAlert('Location fields not found.', 'error');
            return;
        }

        // Show loading state
        latField.value = 'Getting location...';
        lngField.value = 'Getting location...';
        latField.disabled = true;
        lngField.disabled = true;

        navigator.geolocation.getCurrentPosition(
            function (position) {
                latField.value = position.coords.latitude.toFixed(6);
                lngField.value = position.coords.longitude.toFixed(6);
                latField.disabled = false;
                lngField.disabled = false;
                showAlert('Location obtained successfully!', 'success');
            },
            function (error) {
                latField.value = '';
                lngField.value = '';
                latField.disabled = false;
                lngField.disabled = false;

                let errorMessage = 'Unable to get your location. ';
                switch (error.code) {
                    case error.PERMISSION_DENIED:
                        errorMessage += 'Please allow location access and try again.';
                        break;
                    case error.POSITION_UNAVAILABLE:
                        errorMessage += 'Location information is unavailable.';
                        break;
                    case error.TIMEOUT:
                        errorMessage += 'Location request timed out.';
                        break;
                    default:
                        errorMessage += 'An unknown error occurred.';
                        break;
                }
                showAlert(errorMessage, 'warning');
            },
            {
                enableHighAccuracy: true,
                timeout: 10000,
                maximumAge: 60000
            }
        );
    }
</script>
<script>
    // CSV upload handler
    document.getElementById('uploadCsvForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        const input = document.getElementById('csvFileInput');
        if (!input.files || input.files.length === 0) {
            showAlert('Please select a CSV file to upload', 'warning');
            return;
        }

        const formData = new FormData();
        formData.append('csvFile', input.files[0]);

        try {
            const res = await fetch('/api/provider/services/upload-csv', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if (data.success) {
                showAlert(`${data.created} services imported`, 'success');
                loadServices();
            } else {
                showAlert(data.message || 'CSV import failed', 'danger');
                console.error(data);
            }
        } catch (err) {
            console.error('CSV upload error', err);
            showAlert('An error occurred during CSV upload', 'danger');
        }
    });
</script>